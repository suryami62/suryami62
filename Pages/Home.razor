@page "/"

<PageTitle>suryami62</PageTitle>

<div class="hero min-h-screen">
    <div class="hero-content flex-col md:flex-row">
        <div class="avatar">
            <div class="max-w-sm rounded-full">
                <img src="img/photo.webp" />
            </div>
        </div>
        <div class="text-center md:text-left">
            <h1 class="text-5xl font-bold pb-2">SURYA RAMADHAN</h1>
            <span class="font-semibold italic">@@suryami62</span>
            <p class="py-2">Halo all, I am a physics teacher and web/app developer.</p>
            <div class="pt-2.5">
                @foreach (var socialMedia in socialMedias)
                {
                    <a aria-label="@socialMedia.AriaLabel" href="@socialMedia.Href" target="_blank">
                        <i class="@socialMedia.IconClass fa-3x px-2"></i>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private class SocialMediaLink
    {
        public string? AriaLabel { get; set; }
        public string? Href { get; set; }
        public string? IconClass { get; set; }
    }

    private List<SocialMediaLink> socialMedias = new()
    {
        new SocialMediaLink { AriaLabel = "facebook", Href = "https://www.facebook.com/suryami62/", IconClass = "fa-brands fa-square-facebook" },
        new SocialMediaLink { AriaLabel = "instagram", Href = "https://www.instagram.com/suryami62/", IconClass = "fa-brands fa-square-instagram" },
        new SocialMediaLink { AriaLabel = "twitter", Href = "https://twitter.com/suryami62/", IconClass = "fa-brands fa-square-x-twitter" },
        new SocialMediaLink { AriaLabel = "linkedin", Href = "https://www.linkedin.com/in/suryami62/", IconClass = "fa-brands fa-linkedin" }
    };
}