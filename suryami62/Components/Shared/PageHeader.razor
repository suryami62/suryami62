@* Reusable hero-style page header with highlighted title and supporting content. *@
<section class="border-b-4 border-black pb-12 dark:border-white">
    <div class="@GridContainerClass">
        <div class="@TextAlignClass">
            <!-- Title -->
            <h1 class="text-5xl leading-none font-black tracking-tighter uppercase sm:text-6xl md:text-8xl">
                @Title <br/>
                <span class="bg-black px-4 text-white dark:bg-white dark:text-black">@Highlight</span>
            </h1>

            <!-- Description -->
            <div class="@DescriptionClass">
                @ChildContent
            </div>

            <!-- Footer (Socials, etc) -->
            @if (FooterContent is not null)
            {
                <div class="mt-8 flex flex-wrap justify-center gap-4 md:justify-start">
                    @FooterContent
                </div>
            }
        </div>

        <!-- Aside (Avatar, etc) -->
        @if (AsideContent is not null)
        {
            @AsideContent
        }
    </div>
</section>

@code {
    [Parameter] [EditorRequired] public string Title { get; set; } = "";

    [Parameter] [EditorRequired] public string Highlight { get; set; } = "";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public RenderFragment? FooterContent { get; set; }

    [Parameter] public RenderFragment? AsideContent { get; set; }

    private string GridContainerClass
    {
        get
        {
            if (AsideContent is not null)
            {
                return "grid gap-12 md:grid-cols-[1fr_auto] md:items-center";
            }

            return "";
        }
    }

    private string TextAlignClass
    {
        get
        {
            if (AsideContent is not null)
            {
                return "text-center md:text-left";
            }

            return "";
        }
    }

    private string DescriptionClass
    {
        get
        {
            if (AsideContent is not null)
            {
                return "mx-auto md:mx-0 mt-6 max-w-2xl text-xl font-bold md:text-2xl";
            }

            return "mt-6 max-w-2xl text-xl font-bold md:text-2xl";
        }
    }

}