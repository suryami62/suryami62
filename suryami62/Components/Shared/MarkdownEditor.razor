@* Interactive markdown editor with formatting tools and live preview support. *@
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject MarkdownRenderer MarkdownRenderer

<div
    class="neo-card flex flex-col">
    <div class="flex flex-wrap gap-2 border-b-4 border-black bg-gray-50 p-2 dark:border-white dark:bg-gray-900/50">
        <div class="flex gap-1 border-r-2 border-black pr-2 dark:border-white">
            @foreach (var i in Enumerable.Range(1, 6))
            {
                <button type="button" @onclick='() => WrapSelection(new string((char)35, i) + " ", "")'
                        disabled="@IsFormattingDisabled"
                        title="@($"Heading {i}")"
                        class="md-toolbar-btn font-black">
                    H@(i)
                </button>
            }
        </div>

        <div class="flex gap-1 border-r-2 border-black pr-2 dark:border-white">
            <button type="button" @onclick='() => WrapSelection("**", "**")' disabled="@IsFormattingDisabled"
                    title="Bold"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-bold"></i>
            </button>
            <button type="button" @onclick='() => WrapSelection("*", "*")' disabled="@IsFormattingDisabled"
                    title="Italic"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-italic"></i>
            </button>
        </div>

        <div class="flex gap-1 border-r-2 border-black pr-2 dark:border-white">
            <button type="button" @onclick='() => WrapSelection("- ", "")' disabled="@IsFormattingDisabled"
                    title="Unordered List"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-list"></i>
            </button>
            <button type="button" @onclick='() => WrapSelection("1. ", "")' disabled="@IsFormattingDisabled"
                    title="Ordered List"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-list-ol"></i>
            </button>
            <button type="button" @onclick='() => WrapSelection("> ", "")' disabled="@IsFormattingDisabled"
                    title="Blockquote"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-quote-left"></i>
            </button>
            <button type="button" @onclick='() => WrapSelection("\n---\n", "")' disabled="@IsFormattingDisabled"
                    title="Horizontal Rule"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-minus"></i>
            </button>
        </div>

        <div class="flex gap-1 border-r-2 border-black pr-2 dark:border-white">
            <button type="button" @onclick='() => WrapSelection("`", "`")' disabled="@IsFormattingDisabled"
                    title="Inline Code"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-terminal"></i>
            </button>
            <button type="button" @onclick='() => WrapSelection("```\n", "\n```")' disabled="@IsFormattingDisabled"
                    title="Code Block"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-code"></i>
            </button>
        </div>

        <div class="flex gap-1">
            <button type="button" @onclick='() => WrapSelection("[", "](url)")' disabled="@IsFormattingDisabled"
                    title="Link"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-link"></i>
            </button>
            <button type="button" @onclick='() => WrapSelection("![](", ")")' disabled="@IsFormattingDisabled"
                    title="Image"
                    class="md-toolbar-btn">
                <i class="fa-solid fa-image"></i>
            </button>
        </div>

        <div class="grow"></div>

        <div class="flex h-10 border-2 border-black dark:border-white">
            <button type="button" @onclick="() => SetMode(EditorMode.Edit)"
                    class='@(Mode == EditorMode.Edit ? "bg-black dark:bg-white" : "hover:bg-gray-100 dark:hover:bg-gray-800") md-mode-btn'>
                EDIT
            </button>
            <button type="button" @onclick="() => SetMode(EditorMode.Split)"
                    class='@(Mode == EditorMode.Split ? "bg-black dark:bg-white" : "hover:bg-gray-100 dark:hover:bg-gray-800") md-mode-btn border-l-2 border-black dark:border-white'>
                SPLIT
            </button>
            <button type="button" @onclick="() => SetMode(EditorMode.Preview)"
                    class='@(Mode == EditorMode.Preview ? "bg-black dark:bg-white" : "hover:bg-gray-100 dark:hover:bg-gray-800") md-mode-btn border-l-2 border-black dark:border-white'>
                PREVIEW
            </button>
        </div>
    </div>

    <div class="grid @(Mode == EditorMode.Split ? "grid-cols-2" : "grid-cols-1") min-h-[400px]">
        @if (Mode != EditorMode.Preview)
        {
            <textarea @ref="_textArea" value="@Value" @oninput="OnInput"
                      placeholder="Write your story in Markdown..."
                      class="h-full min-h-100 w-full resize-none p-4 font-mono text-lg outline-none dark:bg-gray-900 @(Mode == EditorMode.Split ? "border-r-4 border-black dark:border-white" : "")"></textarea>
        }

        @if (Mode != EditorMode.Edit)
        {
            <div class="prose prose-lg h-full min-h-100 max-w-none overflow-auto p-4 dark:prose-invert">
                @PreviewMarkup
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    private ElementReference _textArea;
    private IJSObjectReference? _module;
    private EditorMode Mode { get; set; } = EditorMode.Edit;
    private bool IsFormattingDisabled => Mode == EditorMode.Preview || _module is null;

    private MarkupString PreviewMarkup => MarkdownRenderer.Render(Value);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/js/markdown-editor.js");
        }
    }

    private void SetMode(EditorMode mode)
    {
        Mode = mode;
    }

    private async Task WrapSelection(string prefix, string suffix)
    {
        if (IsFormattingDisabled || _module is null)
        {
            return;
        }

        var newValue = await _module.InvokeAsync<string>("insertText", _textArea, prefix, suffix);
        Value = newValue;
        await ValueChanged.InvokeAsync(Value);
    }

    private enum EditorMode
    {
        Edit,
        Split,
        Preview
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

}
