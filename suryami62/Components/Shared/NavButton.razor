<NavLink
    class="block translate-x-0 translate-y-0 border-2 border-black bg-white px-6 py-2 font-bold text-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all hover:bg-neutral-300 active:translate-x-1 active:translate-y-1 active:shadow-none dark:border-white dark:bg-black dark:text-white dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)] dark:hover:bg-neutral-700"
    href="@Href">
    @Text
</NavLink>

@code {
    [Parameter] public string? Href { get; set; }

    [Parameter] public string? Text { get; set; }
}
