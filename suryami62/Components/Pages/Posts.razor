@page "/posts"
@using suryami62.Data.Models
@using suryami62.Services
@inject IBlogPostService BlogPostService
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>My Tech Writings | suryami62</PageTitle>

<!-- Meta Section -->
<HeadContent>
    <MetaOpenGraphCard Title="My Tech Writings | suryami62"
                       Description="In-depth tutorials and insights from a .NET Developer and Physics Teacher."
                       Image="@(NavigationManager.BaseUri + Assets["img/socialCard.webp"])"
                       Url="@NavigationManager.Uri"/>
</HeadContent>

<div class="flex flex-col gap-12 py-8">
    <!-- Header Section -->
    <PageHeader Title="My Tech" Highlight="Writings">
        <ChildContent>
            In-depth tutorials and insights from a
            <span class="underline decoration-4">.NET Developer</span> and
            <span class="underline decoration-4">Physics Teacher</span>.
        </ChildContent>
    </PageHeader>

    <!-- Search Section -->
    <section>
        <SearchForm/>
    </section>

    <!-- Blog Posts Grid -->
    <section>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            @if (_posts == null)
            {
                <div class="col-span-full text-center">Loading posts...</div>
            }
            else if (!_posts.Any())
            {
                <div class="col-span-full text-center">No posts found yet. Check back soon!</div>
            }
            else
            {
                @foreach (var post in _posts)
                {
                    <PostCard Label="@post.Label" Date="@post.Date.ToString("MMM dd, yyyy")" Title="@post.Title"
                              Href="@($"/posts/{post.Slug}")" Summary="@post.Summary"/>
                }
            }
        </div>

        @if (_total > _pageSize)
        {
            <div class="mt-12 flex justify-center gap-4">
                <button disabled="@(_page == 1)" @onclick="() => ChangePage(_page - 1)"
                        class="border-4 border-black bg-white px-6 py-2 font-black transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] disabled:opacity-50 disabled:hover:translate-x-0 disabled:hover:translate-y-0 disabled:hover:shadow-none dark:border-white dark:bg-black dark:shadow-[4px_4px_0px_0px_#fff]">
                    PREV
                </button>
                <div class="flex items-center text-2xl font-black">
                    @_page / @(Math.Ceiling((double)_total / _pageSize))
                </div>
                <button disabled="@(_page * _pageSize >= _total)" @onclick="() => ChangePage(_page + 1)"
                        class="border-4 border-black bg-[#A3E635] px-6 py-2 font-black shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] disabled:opacity-50 disabled:hover:translate-x-0 disabled:hover:translate-y-0 disabled:hover:shadow-none dark:border-white dark:bg-lime-500 dark:shadow-[4px_4px_0px_0px_#fff]">
                    NEXT
                </button>
            </div>
        }
    </section>
</div>

@code {
    private List<BlogPost>? _posts;
    private int _page = 1;
    private readonly int _pageSize = 6;
    private int _total;

    protected override async Task OnInitializedAsync()
    {
        await LoadPosts();
    }

    private async Task LoadPosts()
    {
        var (items, total) = await BlogPostService.GetPostsAsync(true, (_page - 1) * _pageSize, _pageSize);
        _posts = items;
        _total = total;
    }

    private async Task ChangePage(int newPage)
    {
        _page = newPage;
        await LoadPosts();
    }

}
