@page "/posts"
@using suryami62.Data.Models
@using suryami62.Services
@inject IBlogPostService BlogPostService

<PageTitle>Blog - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <!-- Header Section -->
    <PageHeader Title="My Tech" Highlight="Writings">
        <ChildContent>
            In-depth tutorials and insights from a
            <span class="underline decoration-4">.NET Developer</span> and
            <span class="underline decoration-4">Physics Teacher</span>.
        </ChildContent>
    </PageHeader>

    <!-- Search Section -->
    <section>
        <SearchForm/>
    </section>

    <!-- Blog Posts Grid -->
    <section>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            @if (_posts == null)
            {
                <div class="col-span-full text-center">Loading posts...</div>
            }
            else if (!_posts.Any())
            {
                <div class="col-span-full text-center">No posts found yet. Check back soon!</div>
            }
            else
            {
                @foreach (var post in _posts)
                {
                    <PostCard Label="@post.Label" Date="@post.Date.ToString("MMM dd, yyyy")" Title="@post.Title"
                              Href="@($"/posts/{post.Slug}")" Summary="@post.Summary"/>
                }
            }
        </div>
    </section>
</div>

@code {
    private List<BlogPost>? _posts;

    protected override async Task OnInitializedAsync()
    {
        _posts = await BlogPostService.GetPostsAsync();
    }

}
