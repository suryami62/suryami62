@page "/projects"
@using suryami62.Domain.Models
@using suryami62.Services
@inject IProjectService ProjectService
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>My Selected Projects | suryami62</PageTitle>

<!-- Meta Section -->
<HeadContent>
    <MetaOpenGraphCard Title="My Selected Projects | suryami62"
                       Description="A collection of tools and experiments built by a .NET Developer and Physics Teacher."
                       Image="@(NavigationManager.BaseUri + Assets["img/socialCard.webp"])"
                       Url="@NavigationManager.Uri"/>
</HeadContent>

<div class="flex flex-col gap-12 py-8">
    <!-- Header Section -->
    <PageHeader Title="My Selected" Highlight="Projects">
        <ChildContent>
            A collection of tools and experiments built by a
            <span class="underline decoration-4">.NET Developer</span> and
            <span class="underline decoration-4">Physics Teacher</span>.
        </ChildContent>
    </PageHeader>

    <!-- Projects Grid -->
    <section>
        <div class="grid gap-12 md:grid-cols-2">
            @if (_projects == null)
            {
                <div class="col-span-full text-center py-12">
                    <p class="text-2xl font-black uppercase">Loading projects...</p>
                </div>
            }
            else if (!_projects.Any())
            {
                <div class="col-span-full text-center py-12 border-4 border-black border-dashed">
                    <p class="text-2xl font-black uppercase">No projects found yet.</p>
                </div>
            }
            else
            {
                @foreach (var project in _projects)
                {
                    <ProjectCard Title="@project.Title" Description="@project.Description"
                                 Tags="@(project.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))"
                                 RepoUrl="@project.RepoUrl?.ToString()" DemoUrl="@project.DemoUrl?.ToString()"
                                 ImageUrl="@project.ImageUrl?.ToString()"/>
                }
            }
        </div>

        @if (_total > _pageSize)
        {
            <div class="mt-12 flex justify-center gap-4">
                <button disabled="@(_page == 1)" @onclick="() => ChangePage(_page - 1)"
                        class="border-4 border-black bg-white px-6 py-2 font-black transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] disabled:opacity-50 disabled:hover:translate-x-0 disabled:hover:translate-y-0 disabled:hover:shadow-none dark:border-white dark:bg-black dark:shadow-[4px_4px_0px_0px_#fff]">
                    PREV
                </button>
                <div class="flex items-center text-2xl font-black">
                    @_page / @(Math.Ceiling((double)_total / _pageSize))
                </div>
                <button disabled="@(_page * _pageSize >= _total)" @onclick="() => ChangePage(_page + 1)"
                        class="border-4 border-black bg-[#FB923C] px-6 py-2 font-black shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] disabled:opacity-50 disabled:hover:translate-x-0 disabled:hover:translate-y-0 disabled:hover:shadow-none dark:border-white dark:bg-orange-400 dark:shadow-[4px_4px_0px_0px_#fff]">
                    NEXT
                </button>
            </div>
        }
    </section>
</div>

@code {
    private List<Project>? _projects;
    private int _page = 1;
    private readonly int _pageSize = 6;
    private int _total;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        var (items, total) = await ProjectService.GetProjectsAsync((_page - 1) * _pageSize, _pageSize);
        _projects = items;
        _total = total;
    }

    private async Task ChangePage(int newPage)
    {
        _page = newPage;
        await LoadProjects();
    }

}
