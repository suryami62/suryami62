@page "/Error"
@using System.Diagnostics
@inject IHostEnvironment Env

<PageTitle>500: System Collapse | suryami62</PageTitle>

<div class="flex flex-col gap-8 py-4 md:gap-12 md:py-8">
    <PageHeader Title="SYSTEM" Highlight="CRASH">
        <ChildContent>
            An unexpected glitch has manifested in the system's core. Our algorithms are frantically trying to
            re-establish order.
        </ChildContent>
        <AsideContent>
            <ErrorGlyph Symbol="!" BackgroundClass="bg-yellow-400 dark:bg-yellow-600"/>
        </AsideContent>
    </PageHeader>

    <div class="grid gap-12 lg:grid-cols-[1fr_2fr]">
        <ErrorSummarySection
            Title="Core Exception"
            Description="The server encountered an internal error or misconfiguration and was unable to complete your request. This is likely a temporary anomaly in the digital fabric.">
            <BodyContent>
                @if (ShowRequestId)
                {
                    <div class="border-2 border-black bg-neutral-100 p-4 dark:border-white dark:bg-neutral-900">
                        <span
                            class="mb-1 block text-xs font-black uppercase italic opacity-60">Tracking Identifier</span>
                        <code class="font-mono text-sm font-bold break-all">@RequestId</code>
                    </div>
                }
            </BodyContent>
        </ErrorSummarySection>

        <div class="space-y-8">
            <ErrorPanel Title="Status Report">
                <ul class="space-y-4 text-sm font-bold text-neutral-600 uppercase dark:text-neutral-400">
                    <li>→ Primary logic gate: [FAILED]</li>
                    <li>→ Resource allocation: [INTERRUPTED]</li>
                    <li>→ User patience level: [CRITICAL]</li>
                </ul>
                <div class="mt-8">
                    <p class="italic">Please try refreshing the page or come back later when the monkeys have finished
                        their coffee.</p>
                </div>
            </ErrorPanel>

            @if (Env.IsDevelopment())
            {
                <div class="border-4 border-red-500 bg-red-100 p-6 text-red-900 dark:bg-red-900 dark:text-red-100">
                    <h4 class="mb-2 text-xl font-black uppercase italic">DEBUG_MODE_ENABLED</h4>
                    <p class="text-sm leading-snug font-bold">
                        Sensitive exception details are visible because you are in the <strong>Development</strong>
                        environment.
                        Check the server console or logs for the full stack trace.
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@code{
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }

}