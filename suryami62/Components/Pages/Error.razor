@page "/Error"
@using System.Diagnostics
@inject IHostEnvironment Env

<PageTitle>500: System Collapse | suryami62</PageTitle>

<div class="flex flex-col gap-8 py-4 md:gap-12 md:py-8">
    <PageHeader Title="SYSTEM" Highlight="CRASH">
        <ChildContent>
            An unexpected glitch has manifested in the system's core. Our algorithms are frantically trying to
            re-establish order.
        </ChildContent>
        <AsideContent>
            <div
                class="flex h-32 w-32 items-center justify-center border-4 border-black bg-yellow-400 text-6xl font-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:bg-yellow-600 dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] md:h-48 md:w-48 md:text-8xl">
                !
            </div>
        </AsideContent>
    </PageHeader>

    <div class="grid gap-12 lg:grid-cols-[1fr_2fr]">
        <div class="flex flex-col gap-6">
            <h3 class="text-2xl font-black uppercase tracking-tighter underline decoration-4 underline-offset-4">
                Core Exception
            </h3>
            <p class="text-lg font-medium leading-relaxed">
                The server encountered an internal error or misconfiguration and was unable to complete your request.
                This is likely a temporary anomaly in the digital fabric.
            </p>

            @if (ShowRequestId)
            {
                <div class="border-2 border-black p-4 bg-neutral-100 dark:bg-neutral-900 dark:border-white">
                    <span class="block text-xs font-black uppercase mb-1 opacity-60 italic">Tracking Identifier</span>
                    <code class="font-mono font-bold break-all text-sm">@RequestId</code>
                </div>
            }

            <div class="mt-4">
                <NavButton Href="/" Text="Back to Reality"/>
            </div>
        </div>

        <div class="space-y-8">
            <div
                class="border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] md:p-10">
                <h3 class="mb-6 text-2xl font-black uppercase tracking-tighter">
                    Status Report
                </h3>
                <ul class="space-y-4 font-bold text-neutral-600 dark:text-neutral-400 uppercase text-sm">
                    <li>→ Primary logic gate: [FAILED]</li>
                    <li>→ Resource allocation: [INTERRUPTED]</li>
                    <li>→ User patience level: [CRITICAL]</li>
                </ul>
                <div class="mt-8">
                    <p class="italic">Please try refreshing the page or come back later when the monkeys have finished
                        their coffee.</p>
                </div>
            </div>

            @if (Env.IsDevelopment())
            {
                <div class="border-4 border-red-500 p-6 bg-red-100 text-red-900 dark:bg-red-900 dark:text-red-100">
                    <h4 class="text-xl font-black uppercase mb-2 italic">DEBUG_MODE_ENABLED</h4>
                    <p class="font-bold text-sm leading-snug">
                        Sensitive exception details are visible because you are in the <strong>Development</strong>
                        environment.
                        Check the server console or logs for the full stack trace.
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@code{
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }

}