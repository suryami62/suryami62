@page "/not-found"
@layout MainLayout

<PageTitle>404: Lost in Space | suryami62</PageTitle>

<div class="flex flex-col gap-8 py-4 md:gap-12 md:py-8">
    <PageHeader Title="ERROR" Highlight="404">
        <ChildContent>
            Maximum Entropy: The page you are looking for has undergone radioactive decay or shifted into another
            dimension.
        </ChildContent>
        <AsideContent>
            <div
                class="flex h-32 w-32 items-center justify-center border-4 border-black bg-white text-6xl font-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:bg-black dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] md:h-48 md:w-48 md:text-8xl">
                ?
            </div>
        </AsideContent>
    </PageHeader>

    <div class="grid gap-12 lg:grid-cols-[1fr_2fr]">
        <div class="flex flex-col gap-6">
            <h3 class="text-2xl font-black uppercase tracking-tighter underline decoration-4 underline-offset-4">
                Uncertainty Principle
            </h3>
            <p class="text-lg font-medium leading-relaxed">
                According to Heisenberg, we know you are looking for something, but this file's position cannot be
                determined. It might be Quantum Tunneling to another directory.
            </p>
            <div class="mt-4">
                <NavButton Href="/" Text="Back to Reality"/>
            </div>
        </div>

        <div
            class="border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] md:p-10">
            <h3 class="mb-6 text-2xl font-black uppercase tracking-tighter">
                Still Lost in the Void?
            </h3>
            <p class="mb-6 font-bold text-neutral-600 dark:text-neutral-400">
                Search the database to find content that hasn't collapsed into a black hole yet.
            </p>
            <SearchForm/>
        </div>
    </div>
</div>
