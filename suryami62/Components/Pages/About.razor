@* This page displays the author's biography and career history.
   It shows work experience and education in a timeline format.
   @page "/about" handles the /about URL.
*@
@page "/about"
@using suryami62.Domain.Models

@* Import the data models we need *@

@* Inject services we need *@
@inject NavigationManager NavigationManager
@inject IJourneyHistoryService JourneyHistoryService
@inject MarkdownRenderer MarkdownRenderer

@* Enable interactive features *@
@rendermode InteractiveServer

@* Set browser tab title *@
<PageTitle>My Personal Bio | suryami62</PageTitle>

<!-- Meta tags for social media sharing -->
<HeadContent>
    <MetaOpenGraphCard Title="My Personal Bio | suryami62"
                       Description="Learn about Surya Ramadhan's journey as a .NET Developer and Physics Teacher. Discover how passion for science and coding shapes problem-solving approaches."
                       Image="@(NavigationManager.BaseUri + Assets["img/socialCard.webp"])"
                       Url="@NavigationManager.Uri"/>
</HeadContent>

<!-- Main content area -->
<div class="flex flex-col gap-12 py-8">

    <!-- Header: Page title -->
    <PageHeader Title="My Personal" Highlight="Bio">
        <ChildContent>
            A <span class="underline decoration-4">.NET Developer</span> and
            <span class="underline decoration-4">Physics Teacher</span>
            bridging the gap between theory and code.
        </ChildContent>
    </PageHeader>

    <!-- Role Cards: Two cards side by side explaining the two roles -->
    <section class="grid gap-8 md:grid-cols-2">
        <!-- Developer Role Card -->
        <InfoCard Title="The Developer" IconClass="fa-solid fa-code">
            <p class="text-lg leading-relaxed font-medium">
                Specializing in <strong>.NET</strong> and <strong>C#</strong>,
                I build robust systems with a focus on logical precision. My approach to coding is grounded in
                analytical thinking by breaking down complex problems into efficient, executable solutions.
            </p>
        </InfoCard>

        <!-- Teacher Role Card -->
        <InfoCard Title="The Teacher" IconClass="fa-solid fa-chalkboard-user">
            <p class="text-lg leading-relaxed font-medium">
                With a background in <strong>Physics Education</strong>, I
                have a passion for simplifying difficult concepts. Whether teaching students about energy sources or
                mentoring peers in code, my goal is always clarity and understanding.
            </p>
        </InfoCard>
    </section>

    <!-- Journey Section: Work Experience and Education Timeline -->
    <section>
        <h2 class="mb-8 text-4xl font-black tracking-tighter uppercase decoration-4 underline-offset-4 md:text-6xl md:underline">
            Journey
        </h2>

        <div class="grid gap-8 lg:grid-cols-2">
            <!-- Work Experience Column -->
            <ContentBlock Title="Experience">
                <div class="flex flex-col gap-6">
                    @* Loop through each job in the experience list *@
                    @foreach (var experience in _journey.Experiences)
                    {
                        <div>
                            @* Job title *@
                            <h4 class="text-2xl font-bold">@experience.Title</h4>

                            @* Company/Organization name *@
                            <p class="text-lg font-bold text-neutral-600 dark:text-neutral-400">@experience.Organization</p>

                            @* Time period (e.g., "2020 - 2023") *@
                            <p class="mb-2 font-mono text-sm">@experience.Period</p>

                            @* Job description (rendered as Markdown) *@
                            @if (HasDescription(experience.Summary))
                            {
                                <div class="prose prose-sm max-w-none font-medium dark:prose-invert">
                                    @RenderMarkdown(experience.Summary)
                                </div>
                            }
                        </div>
                    }
                </div>
            </ContentBlock>

            <!-- Education Column -->
            <ContentBlock Title="Education">
                <div class="flex flex-col gap-6">
                    @* Loop through each school/degree *@
                    @foreach (var education in _journey.Educations)
                    {
                        <div>
                            @* Degree or certification name *@
                            <h4 class="text-2xl font-bold">@education.Title</h4>

                            @* School or institution name *@
                            <p class="text-lg font-bold text-neutral-600 dark:text-neutral-400">@education.Organization</p>

                            @* Time period *@
                            <p class="mb-2 font-mono text-sm">@education.Period</p>

                            @* Education description *@
                            @if (HasDescription(education.Summary))
                            {
                                <div class="prose prose-sm max-w-none font-medium dark:prose-invert">
                                    @RenderMarkdown(education.Summary)
                                </div>
                            }
                        </div>
                    }
                </div>
            </ContentBlock>
        </div>
    </section>
</div>

@code {
    // ============================================================
    // DATA CLASSES
    // ============================================================

    @* This class holds all the journey data for the page.
       We use a simple class instead of 'record' because classes
       are more familiar to beginners. Records are a newer C# feature.*@
    private class JourneyViewModel
    {
        @* List of work experiences (jobs) *@
        public List<JourneyHistory> Experiences { get; }

        @* List of education history (schools, degrees) *@
        public List<JourneyHistory> Educations { get; }

        @* Constructor - creates the object with the two lists *@
        public JourneyViewModel(List<JourneyHistory> experiences, List<JourneyHistory> educations)
        {
            Experiences = experiences;
            Educations = educations;
        }
    }

    // ============================================================
    // FIELDS
    // ============================================================

    @* This holds all the experience and education data.
       It starts with empty lists (new List...).
       The = means "set to this value when page loads". *@
    private JourneyViewModel _journey = new(
        new List<JourneyHistory>(),
        new List<JourneyHistory>()
    );

    // ============================================================
    // PAGE LIFECYCLE
    // ============================================================

    @* This runs automatically when the page first loads.
       It fetches the experience and education data from the database.*@
    protected override async Task OnInitializedAsync()
    {
        // Load work experience from database
        // JourneySection.Experience means "only get work history items"
        var experiences = await JourneyHistoryService.GetBySectionAsync(
            JourneySection.Experience
        );

        // Load education history from database
        // JourneySection.Education means "only get education items"
        var educations = await JourneyHistoryService.GetBySectionAsync(
            JourneySection.Education
        );

        // Create the view model with both lists
        _journey = new JourneyViewModel(experiences, educations);
    }

    // ============================================================
    // HELPER METHODS
    // ============================================================

    @* Checks if a description exists (not null or empty).
       Returns true if there is text to display.*@
    private bool HasDescription(string? summary)
    {
        // string.IsNullOrWhiteSpace returns true if the text is
        // null, empty, or only whitespace. The ! means "not",
        // so this returns true if there IS actual content.
        return !string.IsNullOrWhiteSpace(summary);
    }

    @* Renders Markdown text to HTML.
       Markdown is a simple way to format text (like **bold** or *italic*).
       This converts it to proper HTML for the browser.*@
    private MarkupString RenderMarkdown(string? markdownText)
    {
        if (string.IsNullOrWhiteSpace(markdownText))
        {
            // Return empty HTML if no text
            return new MarkupString("");
        }

        // Convert Markdown to HTML and return it
        return MarkdownRenderer.Render(markdownText);
    }

}