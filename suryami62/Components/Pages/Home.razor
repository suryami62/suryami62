@page "/"
@inject IConfiguration Configuration

<PageTitle>Home</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <!-- Header Section -->
    <section class="border-b-4 border-black pb-12 dark:border-white">
        <div class="grid gap-12 md:grid-cols-[1fr_auto] md:items-center">
            <div class="text-center md:text-left">
                <!-- Intro -->
                <h1 class="text-5xl leading-none font-black tracking-tighter uppercase sm:text-6xl md:text-8xl">
                    My Personal<br/>
                    <span class="bg-black px-4 text-white dark:bg-white dark:text-black">Blog</span>
                </h1>

                <!-- Description -->
                <p class="mx-auto mt-6 max-w-2xl text-xl font-bold md:mx-0 md:text-2xl">
                    Hi, I'm
                    <span
                        class="underline decoration-4">
                        Surya Ramadhan
                    </span>. A .NET Developer and Physics Teacher
                    sharing insights on minimal design, coding, and learning.
                </p>

                <!-- Social Buttons -->
                <div class="mt-8 flex flex-wrap justify-center gap-4 md:justify-start">
                    @foreach (var social in Socials)
                    {
                        <SocialButton Href="@social.Href" IconClass="@social.IconClass"/>
                    }
                </div>
            </div>

            <!-- Image Profile -->
            <Avatar AvatarUrl="@Assets["img/photo.webp"]" Alt="Surya Ramadhan"/>
        </div>
    </section>

    <!-- Latest Post Section -->
    <section>
        <div class="mb-12 flex items-end justify-between border-b-4 border-black pb-4 dark:border-white">
            <h2 class="text-4xl font-black tracking-tighter uppercase md:text-6xl">Latest Writings</h2>
            <a href="posts"
               class="hidden text-xl font-bold uppercase underline decoration-4 underline-offset-4 hover:text-neutral-600 md:block dark:hover:text-neutral-400">
                View All Posts
            </a>
        </div>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            @foreach (var post in _posts)
            {
                <PostCard Label="@post.Label" Date="@post.Date" Title="@post.Title" Href="#" Summary="@post.Summary"/>
            }
        </div>
    </section>
</div>

@code {

    private record Social(string Href, string IconClass);

    private record Post(string Title, string Label, string Date, string Summary);

    private List<Social> Socials { get; set; } = [];

    protected override void OnInitialized()
    {
        Socials =
        [
            new Social(Configuration["UserInfo:Instagram"] ?? "#", "fa-brands fa-instagram"),
            new Social(Configuration["UserInfo:Linkedin"] ?? "#", "fa-brands fa-linkedin"),
            new Social(Configuration["UserInfo:Github"] ?? "#", "fa-brands fa-github"),
            new Social(Configuration["UserInfo:Email"] ?? "#", "fa-regular fa-envelope")
        ];
    }

    private readonly List<Post> _posts =
    [
        new(
            "The Art of Neo-Brutalism",
            "Design",
            "Dec 27, 2025",
            "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vestibulum mattis odio et magna suscipit, sed fermentum sapien viverra."
        ),

        new(
            "Mastering Blazor & Tailwind",
            "Dev",
            "Dec 20, 2025",
            "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vestibulum mattis odio et magna suscipit, sed fermentum sapien viverra."
        ),

        new(
            "Minimalist Workspace Setup",
            "Lifestyle",
            "Dec 15, 2025",
            "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vestibulum mattis odio et magna suscipit, sed fermentum sapien viverra."
        )
    ];


}