@page "/blog"
@using suryami62.Models
@using suryami62.Services
@using System.Text.RegularExpressions
@inject IBloggerService BloggerService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Blog</PageTitle>

<div class="container">
    <h1 class="mb-4">Blog</h1>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Search posts..." value="@searchQuery" @oninput="HandleInput" />
                <button class="btn btn-primary" @onclick="() => SearchPosts(searchQuery)">Search</button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (posts == null || !posts.Any())
    {
        <div class="alert alert-info">No posts found. @(string.IsNullOrEmpty(searchQuery) ? "" : "Try a different search term.")</div>
    }
    else
    {
        <div class="row">
            @foreach (var post in posts)
            {
                <div class="col-12 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="/blog/@post.Id" class="text-decoration-none">@post.Title</a>
                            </h5>
                            <h6 class="card-subtitle mb-2 text-muted">@post.Published.ToLocalTime().ToString("f")</h6>
                            <p class="card-text">
                                @GetExcerpt(post.Content)
                            </p>
                            <a href="/blog/@post.Id" class="card-link">Read more</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<BlogPost> posts = new();
    private string searchQuery = "";
    private bool isLoading = true;
    private string? errorMessage;
    private CancellationTokenSource? _searchCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadPosts();
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? "";
        
        // Debounce logic
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(500, token); // Debounce time
            await SearchPosts(searchQuery);
        }
        catch (TaskCanceledException)
        {
            // Ignore if cancelled
        }
    }

    private async Task PerformFetch(Func<Task<ServiceResult<PostList>>> fetchAction)
    {
        isLoading = true;
        errorMessage = null;
        // Force UI update for loading state if called from background
        StateHasChanged();

        try 
        {
            var result = await fetchAction();
            if (result.Success)
            {
                posts = result.Data?.Items ?? new List<BlogPost>();
            }
            else
            {
                errorMessage = result.ErrorMessage;
                posts = new List<BlogPost>();
            }
        }
        catch (Exception ex) 
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        
        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadPosts()
    {
        await PerformFetch(() => BloggerService.GetPostsAsync());
    }

    private async Task SearchPosts(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            await LoadPosts();
            return;
        }

        await PerformFetch(() => BloggerService.SearchPostsAsync(query));
    }

    private string GetExcerpt(string content)
    {
        if (string.IsNullOrEmpty(content)) return string.Empty;
        
        // Remove HTML tags
        var plainText = Regex.Replace(content, "<.*?>", string.Empty);
        
        if (plainText.Length > 200)
        {
            return plainText.Substring(0, 200) + "...";
        }
        return plainText;
    }
}
