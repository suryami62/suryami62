@page "/blog/{Id}"
@page "/blog/path/{*Path}"
@using suryami62.Models
@using suryami62.Services
@using Ganss.Xss
@inject IBloggerService BloggerService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(post?.Title ?? "Blog Post")</PageTitle>

<div class="container mt-4">
    <a href="/blog" class="btn btn-outline-secondary mb-3">&larr; Back to Blog</a>

    @if (isLoading)
    {
         <div class="d-flex justify-content-center my-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
         <div class="alert alert-danger">@errorMessage</div>
    }
    else if (post == null)
    {
        <div class="alert alert-warning">Post not found.</div>
    }
    else
    {
        <article>
            <h1 class="display-4 mb-3">@post.Title</h1>
            <div class="text-muted mb-4 border-bottom pb-3">
                <span>Published on @post.Published.ToLocalTime().ToString("f")</span>
                @if(!string.IsNullOrEmpty(post.Url)) {
                    <span class="mx-2">|</span>
                    <a href="@post.Url" target="_blank" class="text-decoration-none">View on Blogger</a>
                }
            </div>
            
            <div class="blog-content">
                @((MarkupString)Sanitize(post.Content))
            </div>
        </article>
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Path { get; set; }

    private BlogPost? post;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        post = null;

        ServiceResult<BlogPost>? result = null;

        try 
        {
            if (!string.IsNullOrEmpty(Id))
            {
                result = await BloggerService.GetPostByIdAsync(Id);
            }
            else if (!string.IsNullOrEmpty(Path))
            {
                var lookupPath = Path.StartsWith("/") ? Path : "/" + Path;
                result = await BloggerService.GetPostByPathAsync(lookupPath);
            }
            else
            {
                 isLoading = false;
                 return;
            }

            if (result != null)
            {
                if (result.Success)
                {
                    post = result.Data;
                }
                else
                {
                    errorMessage = result.ErrorMessage;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }

        isLoading = false;
    }

    private string Sanitize(string html)
    {
        var sanitizer = new HtmlSanitizer();
        return sanitizer.Sanitize(html);
    }
}
