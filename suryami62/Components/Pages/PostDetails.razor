@page "/posts/{Slug}"
@using Markdig
@using suryami62.Data.Models
@using suryami62.Services
@inject IBlogPostService BlogPostService
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>@(_post?.Title is { Length: > 0 } title ? $"{title} | suryami62" : "Post | suryami62")</PageTitle>

<!-- Meta Section -->
<HeadContent>
    <MetaOpenGraphCard Title="@(_post?.Title is { Length: > 0 } title ? $"{title} | suryami62" : "Post | suryami62")"
                       Description="@(_post?.Summary ?? string.Empty)"
                       Image="@(NavigationManager.BaseUri + Assets["img/socialCard.webp"])"
                       Url="@NavigationManager.Uri"/>
</HeadContent>

<div class="flex flex-col gap-8 py-8">
    <div>
        <a href="/posts"
           class="inline-flex items-center gap-2 text-xl font-bold uppercase underline decoration-4 underline-offset-4 hover:text-neutral-600 dark:hover:text-neutral-400">
            <i class="fa-solid fa-arrow-left"></i>
            Back
        </a>
    </div>

    @if (!_isLoaded)
    {
        <div class="text-center text-xl font-bold">Loading post...</div>
    }
    else if (_post is null)
    {
        <div
            class="border-4 border-black bg-white p-6 font-bold shadow-[8px_8px_0px_0px_#000] dark:border-white dark:bg-black dark:shadow-[8px_8px_0px_0px_#fff]">
            <h1 class="mb-2 text-3xl font-black uppercase">Post not found</h1>
            <p class="text-lg">Post not found or not yet published.</p>
        </div>
    }
    else
    {
        <article class="mx-auto w-full max-w-4xl">
            <header class="mb-8 border-b-4 border-black pb-6 dark:border-white">
                <div class="mb-4 flex flex-wrap items-center gap-4">
					<span
                        class="bg-black px-3 py-1 text-sm font-bold text-white uppercase dark:bg-white dark:text-black">
						@_post.Label
					</span>
                    <span class="font-mono font-bold">@_post.Date.ToString("MMM dd, yyyy")</span>
                </div>

                <h1 class="text-4xl font-black tracking-tighter uppercase md:text-6xl">@_post.Title</h1>

                @if (!string.IsNullOrWhiteSpace(_post.Summary))
                {
                    <p class="mt-4 text-xl font-bold text-gray-700 dark:text-gray-300">@_post.Summary</p>
                }
            </header>

            @if (!string.IsNullOrWhiteSpace(_post.ImageUrl))
            {
                <div
                    class="mb-8 border-4 border-black bg-white p-2 shadow-[8px_8px_0px_0px_#000] dark:border-white dark:bg-black dark:shadow-[8px_8px_0px_0px_#fff]">
                    <img src="@_post.ImageUrl" alt="@_post.Title" class="h-auto w-full" loading="lazy"/>
                </div>
            }

            <div class="prose prose-lg max-w-none text-justify dark:prose-invert">
                @((MarkupString)Markdown.ToHtml(_post.Content ?? string.Empty, _pipeline))
            </div>
        </article>
    }
</div>



@code {
    [Parameter] public string? Slug { get; set; }

    private BlogPost? _post;
    private bool _isLoaded;

    private readonly MarkdownPipeline _pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    protected override async Task OnParametersSetAsync()
    {
        _isLoaded = false;
        _post = null;

        if (string.IsNullOrWhiteSpace(Slug))
        {
            _isLoaded = true;
            return;
        }

        var post = await BlogPostService.GetPostBySlugAsync(Slug);
        _post = post is { IsPublished: true } ? post : null;
        _isLoaded = true;
    }

}
