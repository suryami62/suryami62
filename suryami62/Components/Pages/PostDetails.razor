@* Public blog post detail page for rendering a single article by slug. *@
@page "/posts/{Slug}"
@using suryami62.Domain.Models
@inject IBlogPostService BlogPostService
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject MarkdownRenderer MarkdownRenderer

<PageTitle>@PostPageTitle</PageTitle>

<!-- Meta Section -->
<HeadContent>
    <MetaOpenGraphCard Title="@PostPageTitle"
                       Description="@(_post?.Summary ?? string.Empty)"
                       Image="@(NavigationManager.BaseUri + Assets["img/socialCard.webp"])"
                       Url="@NavigationManager.Uri"/>
</HeadContent>

<div class="flex flex-col gap-8 py-8">
    <div>
        <a href="/posts"
           class="neo-inline-link">
            <i class="fa-solid fa-arrow-left"></i>
            Back
        </a>
    </div>

    @if (!_isLoaded)
    {
        <div class="neo-card p-12 text-center">
            <p class="neo-title-md">Loading post...</p>
        </div>
    }
    else if (_post is null)
    {
        <div class="neo-card p-8">
            <h1 class="neo-title-md mb-2">Post not found</h1>
            <p class="text-lg font-bold">Post not found or not yet published.</p>
        </div>
    }
    else
    {
        <article class="mx-auto w-full max-w-4xl">
            <header class="mb-8 border-b-4 border-black pb-6 dark:border-white">
                <div class="mb-4 flex flex-wrap items-center gap-4">
                    <span class="neo-pill">@_post.Label</span>
                    <span class="font-mono text-sm font-bold">@_post.Date.ToString("MMM dd, yyyy")</span>
                </div>

                <h1 class="neo-title-lg">@_post.Title</h1>

                @if (!string.IsNullOrWhiteSpace(_post.Summary))
                {
                    <p class="mt-4 text-xl font-bold text-gray-700 dark:text-gray-300">@_post.Summary</p>
                }
            </header>

            @if (_post.ImageUrl is not null)
            {
                <div class="neo-card mb-8 p-2">
                    <img src="@_post.ImageUrl" alt="@_post.Title" class="h-auto w-full" loading="lazy"/>
                </div>
            }

            <div class="prose prose-lg max-w-none text-justify dark:prose-invert">
                @MarkdownRenderer.Render(_post.Content)
            </div>
        </article>
    }
</div>



@code {
    [Parameter] public string? Slug { get; set; }

    private BlogPost? _post;
    private bool _isLoaded;

    // Builds the page title from the post's title, or falls back to a generic label.
    private string PostPageTitle
    {
        get
        {
            if (_post != null && !string.IsNullOrEmpty(_post.Title))
            {
                return $"{_post.Title} | suryami62";
            }

            return "Post | suryami62";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _isLoaded = false;
        _post = null;

        if (string.IsNullOrWhiteSpace(Slug))
        {
            _isLoaded = true;
            return;
        }

        var post = await BlogPostService.GetPostBySlugAsync(Slug);

        // Only show the post if it has been published.
        if (post != null && post.IsPublished)
        {
            _post = post;
        }

        _isLoaded = true;
    }

}
