@page "/blog/{Id}"
@page "/blog/path/{*Path}"
@using Ganss.Xss
@using suryami62.Models
@using suryami62.Services
@inject IBloggerService BloggerService
@rendermode InteractiveServer

<PageTitle>@(_post?.Title ?? "Blog Post")</PageTitle>

<div class="container mt-4">
    <a href="/blog" class="btn btn-outline-secondary mb-3">&larr; Back to Blog</a>

    @if (_isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
    else if (_post == null)
    {
        <div class="alert alert-warning">Post not found.</div>
    }
    else
    {
        <article>
            <h1 class="display-4 mb-3">@_post.Title</h1>
            <div class="text-muted mb-4 border-bottom pb-3">
                <span>Published on @_post.Published.ToLocalTime().ToString("f")</span>
                @if (!string.IsNullOrEmpty(_post.Url))
                {
                    <span class="mx-2">|</span>
                    <a href="@_post.Url" target="_blank" class="text-decoration-none">View on Blogger</a>
                }
            </div>

            <div class="blog-content">
                @((MarkupString)Sanitize(_post.Content))
            </div>
        </article>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }

    [Parameter] public string? Path { get; set; }

    private BlogPost? _post;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _post = null;

        ServiceResult<BlogPost>? result;

        try
        {
            if (!string.IsNullOrEmpty(Id))
            {
                result = await BloggerService.GetPostByIdAsync(Id);
            }
            else if (!string.IsNullOrEmpty(Path))
            {
                var lookupPath = Path.StartsWith("/") ? Path : "/" + Path;
                result = await BloggerService.GetPostByPathAsync(lookupPath);
            }
            else
            {
                _isLoading = false;
                return;
            }

            if (result.Success)
            {
                _post = result.Data;
            }
            else
            {
                _errorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unexpected error: {ex.Message}";
        }

        _isLoading = false;
    }

    private string Sanitize(string html)
    {
        var sanitizer = new HtmlSanitizer();
        return sanitizer.Sanitize(html);
    }

}
