@* Primary layout that wraps routed pages with the navigation header, main content area, and footer. *@
@inherits LayoutComponentBase

<div
    class="flex min-h-screen flex-col bg-white font-sans text-black selection:bg-black selection:text-white dark:bg-black dark:text-white dark:selection:bg-white dark:selection:text-black">
    <NavMenu/>

    <main class="mx-auto w-full max-w-7xl flex-1 p-4 md:p-8">
        <article class="max-w-none">
            @Body
        </article>
    </main>

    <Footer/>
</div>
