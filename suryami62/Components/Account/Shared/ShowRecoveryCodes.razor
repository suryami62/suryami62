<StatusMessage Message="@StatusMessage"/>
<div class="flex flex-col gap-4">
    <h3 class="text-2xl font-black uppercase tracking-tighter">Recovery codes</h3>
    <div
        class="border-4 border-black bg-neutral-100 p-4 font-bold shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:bg-neutral-900 dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)]"
        role="alert">
        <p>
            <strong>Put these codes in a safe place.</strong>
        </p>
        <p>
            If you lose your device and don't have the recovery codes you will lose access to your account.
        </p>
    </div>
    <div class="grid gap-2 sm:grid-cols-2">
        @foreach (var recoveryCode in RecoveryCodes)
        {
            <code
                class="border-2 border-black bg-white px-3 py-2 text-sm font-bold shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:bg-black dark:shadow-[3px_3px_0px_0px_rgba(255,255,255,1)]">@recoveryCode</code>
        }
    </div>
</div>

@code {
    [Parameter] public string[] RecoveryCodes { get; set; } = [];

    [Parameter] public string? StatusMessage { get; set; }
}