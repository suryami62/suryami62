@* Layout wrapper used by account management pages inside the main site layout. *@
@inherits LayoutComponentBase
@layout MainLayout

<div class="flex flex-col gap-8 py-8">
    <header class="neo-section">
        <h1 class="neo-title-lg">Manage your account</h1>
        <p class="mt-2 text-lg font-bold">Change your account settings</p>
    </header>

    <div class="grid gap-8 lg:grid-cols-[240px_minmax(0,1fr)]">
        <aside class="neo-card-sm p-4">
            <ManageNavMenu/>
        </aside>
        <section class="neo-card p-6">
            @Body
        </section>
    </div>
</div>