@* Layout wrapper used by account management pages inside the main site layout. *@
@inherits LayoutComponentBase
@layout MainLayout

<div class="flex flex-col gap-8 py-8">
    <header class="border-b-4 border-black pb-6 dark:border-white">
        <h1 class="text-4xl font-black tracking-tighter uppercase md:text-5xl">Manage your account</h1>
        <p class="mt-2 text-lg font-bold">Change your account settings</p>
    </header>

    <div class="grid gap-8 lg:grid-cols-[240px_minmax(0,1fr)]">
        <aside class="neo-card p-4">
            <ManageNavMenu/>
        </aside>
        <section class="neo-card p-6">
            @Body
        </section>
    </div>
</div>