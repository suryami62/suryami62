@* Account page shown when an authenticated user lacks permission to access the requested resource. *@
@page "/Account/AccessDenied"

<PageTitle>Access denied</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <header class="border-b-4 border-black pb-6 dark:border-white">
        <h1 class="text-4xl font-black tracking-tighter uppercase md:text-5xl">Access denied</h1>
        <p class="mt-2 text-lg font-bold">You do not have access to this resource.</p>
    </header>
    <div class="neo-card bg-neutral-100 p-6 font-bold dark:bg-neutral-900">
        If you think this is a mistake, contact support or return to the home page.
    </div>
</div>