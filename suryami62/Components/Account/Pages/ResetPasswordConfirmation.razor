@page "/Account/ResetPasswordConfirmation"
<PageTitle>Reset password confirmation</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <header class="border-b-4 border-black pb-6 dark:border-white">
        <h1 class="text-4xl font-black tracking-tighter uppercase md:text-5xl">Reset password confirmation</h1>
    </header>
    <div class="neo-card max-w-xl p-6 font-bold" role="alert">
        Your password has been reset. Please
        <a class="@InlineLinkClass"
           href="Account/Login">click here to log in</a>.
    </div>
</div>

@code {
    private const string InlineLinkClass = "underline decoration-4 underline-offset-4 hover:text-neutral-600 dark:hover:text-neutral-300";
}