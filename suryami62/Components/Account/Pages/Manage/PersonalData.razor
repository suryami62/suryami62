@page "/Account/Manage/PersonalData"
@using Microsoft.AspNetCore.Identity
@using suryami62.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Personal Data</PageTitle>

<div class="flex flex-col gap-6">
    <div>
        <h3 class="text-3xl font-black uppercase tracking-tighter">Personal data</h3>
        <p class="mt-2 text-sm font-bold uppercase">Download or delete your data.</p>
    </div>

    <StatusMessage/>

    <div class="flex flex-col gap-4 max-w-2xl">
        <p class="font-bold">
            Your account contains personal data that you have given us. This page allows you to download or delete that data.
        </p>
        <div
            class="border-4 border-black bg-yellow-100 p-4 font-bold shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:bg-yellow-900/40 dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)]">
            <strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
        </div>
        <div class="flex flex-wrap gap-3">
            <form action="Account/Manage/DownloadPersonalData" method="post">
                <AntiforgeryToken/>
                <button type="submit"
                        class="translate-x-0 translate-y-0 border-2 border-black bg-black px-4 py-2 text-sm font-bold uppercase text-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all hover:bg-neutral-800 active:translate-x-1 active:translate-y-1 active:shadow-none dark:border-white dark:bg-white dark:text-black dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)] dark:hover:bg-neutral-200">
                    Download
                </button>
            </form>
            <a href="Account/Manage/DeletePersonalData"
               class="translate-x-0 translate-y-0 border-2 border-black bg-red-600 px-4 py-2 text-sm font-bold uppercase text-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all hover:bg-red-700 active:translate-x-1 active:translate-y-1 active:shadow-none dark:border-white dark:bg-red-500 dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)]">
                Delete
            </a>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }

}