@page "/Account/Manage/SeoFiles"
@using Microsoft.EntityFrameworkCore
@using suryami62.Data
@using suryami62.Domain.Models
@inject ApplicationDbContext DbContext

<PageTitle>SEO Files Configuration</PageTitle>

<div class="flex flex-col gap-6">
    <div>
        <h3 class="text-3xl font-black tracking-tighter uppercase">SEO Files</h3>
        <p class="mt-2 text-sm font-bold uppercase">Configure sitemap.xml and robots.txt.</p>
    </div>

    @if (showSuccessMessage)
    {
        <div class="@SuccessMessageClass">
            Settings saved successfully.
        </div>
    }

    <EditForm Model="Input" OnValidSubmit="OnValidSubmitAsync" FormName="seo-files-form" method="post">
        <DataAnnotationsValidator/>
        <ValidationSummary class="@ValidationSummaryClass" role="alert"/>

        <div class="mt-4 flex max-w-xl flex-col gap-4">
            <div class="flex flex-col gap-2">
                <label for="baseUrl" class="text-sm font-black tracking-widest uppercase">Base URL (leave empty for
                    auto)</label>
                <InputText id="baseUrl" @bind-Value="Input.BaseUrl"
                           class="@InputClass"
                           placeholder="https://example.com"/>
            </div>

            <div class="flex items-center gap-2">
                <InputCheckbox id="enableSitemap" @bind-Value="Input.EnableSitemap"
                               class="@CheckboxClass"/>
                <label for="enableSitemap" class="text-sm font-black tracking-widest uppercase">Enable
                    sitemap.xml</label>
            </div>

            <div class="flex items-center gap-2">
                <InputCheckbox id="enableRobots" @bind-Value="Input.EnableRobots"
                               class="@CheckboxClass"/>
                <label for="enableRobots" class="text-sm font-black tracking-widest uppercase">Enable robots.txt</label>
            </div>

            <div class="flex flex-col gap-2">
                <label for="robotsDisallow" class="text-sm font-black tracking-widest uppercase">Robots Disallow (one
                    per line)</label>
                <InputTextArea id="robotsDisallow" @bind-Value="Input.RobotsDisallow"
                               class="@InputClass"
                               rows="5" placeholder="/Account"/>
            </div>

            <button type="submit" class="@PrimaryButtonClass">
                Save
            </button>
        </div>
    </EditForm>
</div>

@code {
    private const string InputClass = "neo-input";
    private const string CheckboxClass = "h-5 w-5 border-2 border-black bg-white accent-black dark:border-white dark:bg-black dark:accent-white";
    private const string ValidationSummaryClass = "text-sm font-bold text-red-600 dark:text-red-400";
    private const string SuccessMessageClass = "neo-card mb-4 bg-green-400 px-4 py-3 font-bold text-black";
    private const string PrimaryButtonClass = "neo-button w-full text-center";

    private bool showSuccessMessage;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm] private InputModel Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new InputModel();

        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            var baseUrlSetting = await DbContext.Settings.FirstOrDefaultAsync(s => s.Key == "Seo:BaseUrl");
            var enableSitemapSetting = await DbContext.Settings.FirstOrDefaultAsync(s => s.Key == "Seo:EnableSitemap");
            var enableRobotsSetting = await DbContext.Settings.FirstOrDefaultAsync(s => s.Key == "Seo:EnableRobots");
            var robotsDisallowSetting = await DbContext.Settings.FirstOrDefaultAsync(s => s.Key == "Seo:RobotsDisallow");

            Input.BaseUrl = baseUrlSetting?.Value ?? "";
            Input.EnableSitemap = enableSitemapSetting?.Value != "false";
            Input.EnableRobots = enableRobotsSetting?.Value != "false";
            Input.RobotsDisallow = robotsDisallowSetting?.Value ?? "/Account";
        }
    }

    private async Task OnValidSubmitAsync()
    {
        await SaveSettingAsync("Seo:BaseUrl", Input.BaseUrl ?? "");
        await SaveSettingAsync("Seo:EnableSitemap", Input.EnableSitemap ? "true" : "false");
        await SaveSettingAsync("Seo:EnableRobots", Input.EnableRobots ? "true" : "false");
        await SaveSettingAsync("Seo:RobotsDisallow", Input.RobotsDisallow ?? "");

        await DbContext.SaveChangesAsync();
        showSuccessMessage = true;
    }

    private async Task SaveSettingAsync(string key, string value)
    {
        var setting = await DbContext.Settings.FirstOrDefaultAsync(s => s.Key == key);
        if (setting == null)
        {
            setting = new Setting { Key = key, Value = value };
            DbContext.Settings.Add(setting);
        }
        else
        {
            setting.Value = value;
        }
    }

    private sealed class InputModel
    {
        public string? BaseUrl { get; set; }
        public bool EnableSitemap { get; set; } = true;
        public bool EnableRobots { get; set; } = true;
        public string? RobotsDisallow { get; set; } = "/Account";
    }

}
