@page "/Account/Lockout"

<PageTitle>Locked out</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <header class="border-b-4 border-black pb-6 dark:border-white">
        <h1 class="text-4xl font-black tracking-tighter uppercase md:text-5xl">Locked out</h1>
        <p class="mt-2 text-lg font-bold" role="alert">This account has been locked out. Please try again later.</p>
    </header>
    <div class="neo-card max-w-xl p-6 font-bold">
        If this keeps happening, reset your password or contact support.
    </div>
</div>