@* Admin overview page for managing content counts and application-level switches. *@
@page "/Account/Admin"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject IBlogPostService BlogPostService
@inject IProjectService ProjectService
@inject ApplicationSettingsStore ApplicationSettingsStore

<PageTitle>Admin Dashboard - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <PageHeader Title="Admin" Highlight="Dashboard">
        <ChildContent>
            Manage your blog posts, projects, and other content.
        </ChildContent>
    </PageHeader>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <InfoCard Title="System" IconClass="fas fa-server">
            <div class="flex flex-col gap-4">
                <div class="flex items-center justify-between">
                    <span>Registration:</span>
                    <button @onclick="ToggleRegistrationAsync"
                            class="@RegistrationButtonClass">
                        @RegistrationStatusText
                    </button>
                </div>
                <p class="text-xs text-neutral-500">Enable or disable new user registration.</p>
            </div>
        </InfoCard>

        <InfoCard Title="Posts" IconClass="fas fa-newspaper">
            <div class="flex flex-col gap-4">
                <p>Total posts: @(_postCount)</p>
                <a href="/Account/Admin/Posts"
                   class="@PostsButtonClass">
                    MANAGE POSTS
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Projects" IconClass="fas fa-project-diagram">
            <div class="flex flex-col gap-4">
                <p>Total projects: @(_projectCount)</p>
                <a href="/Account/Admin/Projects"
                   class="@ProjectsButtonClass">
                    MANAGE PROJECTS
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Media" IconClass="fas fa-images">
            <div class="flex flex-col gap-4">
                <p>Manage images and assets.</p>
                <a href="/Account/Admin/Media"
                   class="@MediaButtonClass">
                    MEDIA GALLERY
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Journey" IconClass="fas fa-user-graduate">
            <div class="flex flex-col gap-4">
                <p>Manage your experience and education history.</p>
                <a href="/Account/Admin/Journey"
                   class="@JourneyButtonClass">
                    MANAGE JOURNEY
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Site Profile" IconClass="fas fa-address-card">
            <div class="flex flex-col gap-4">
                <p>Manage global social links and public contact details.</p>
                <a href="/Account/Admin/SiteProfile"
                   class="@SiteProfileButtonClass">
                    SITE PROFILE
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="SEO" IconClass="fas fa-globe">
            <div class="flex flex-col gap-4">
                <p>Manage sitemap and robots configuration.</p>
                <a href="/Account/Admin/SeoFiles"
                   class="@SeoButtonClass">
                    SEO FILES
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Account" IconClass="fas fa-user-cog">
            <div class="flex flex-col gap-4">
                <p>Manage your own account settings.</p>
                <a href="/Account/Manage"
                   class="@SettingsButtonClass">
                    ACCOUNT SETTINGS
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Logout" IconClass="fas fa-sign-out-alt">
            <div class="flex flex-col gap-4">
                <p>Sign out of your account.</p>
                <form action="/Account/Logout" method="post">
                    <AntiforgeryToken/>
                    <input type="hidden" name="ReturnUrl" value=""/>
                    <button type="submit"
                            class="@LogoutButtonClass">
                        LOGOUT
                    </button>
                </form>
            </div>
        </InfoCard>
    </div>
</div>

@code {

    private const int CountOnlyTakeAll = 0;

    private string RegistrationButtonClass =>
        _registrationEnabled ? "neo-button-green px-3 py-1 text-sm w-full text-center" : "neo-button-danger px-3 py-1 text-sm w-full text-center";

    private string RegistrationStatusText => _registrationEnabled ? "ENABLED" : "DISABLED";

    private const string PostsButtonClass = "neo-button-lime w-full px-4 py-2 text-center";
    private const string ProjectsButtonClass = "neo-button-orange w-full px-4 py-2 text-center";
    private const string MediaButtonClass = "neo-button-purple w-full px-4 py-2 text-center";
    private const string JourneyButtonClass = "neo-button-blue w-full px-4 py-2 text-center";
    private const string SiteProfileButtonClass = "neo-button-yellow w-full px-4 py-2 text-center";
    private const string SeoButtonClass = "neo-button-pink w-full px-4 py-2 text-center";
    private const string SettingsButtonClass = "neo-button-blue w-full px-4 py-2 text-center";
    private const string LogoutButtonClass = "neo-button-danger w-full px-4 py-2 text-center";

    private int _postCount;
    private int _projectCount;
    private bool _registrationEnabled;

    /// <summary>
    ///     Loads the dashboard data required for the initial admin overview.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    /// <summary>
    ///     Loads counters and switches shown on the admin landing page.
    /// </summary>
    private async Task LoadDashboardAsync()
    {
        _postCount = await LoadPostCountAsync();
        _projectCount = await LoadProjectCountAsync();
        _registrationEnabled = await LoadRegistrationStateAsync();
    }

    /// <summary>
    ///     Reads the total number of blog posts without loading a paged list into the UI.
    /// </summary>
    private async Task<int> LoadPostCountAsync()
    {
        var (_, totalPosts) = await BlogPostService.GetPostsAsync(false, take: CountOnlyTakeAll);
        return totalPosts;
    }

    /// <summary>
    ///     Reads the total number of projects for the dashboard summary card.
    /// </summary>
    private async Task<int> LoadProjectCountAsync()
    {
        var (_, totalProjects) = await ProjectService.GetProjectsAsync(take: CountOnlyTakeAll);
        return totalProjects;
    }

    /// <summary>
    ///     Loads the persisted registration switch so the dashboard reflects the current site behavior.
    /// </summary>
    private async Task<bool> LoadRegistrationStateAsync()
    {
        var settings = await ApplicationSettingsStore.GetAsync();
        return settings.RegistrationEnabled;
    }

    /// <summary>
    ///     Toggles public registration and persists the new state immediately.
    /// </summary>
    private async Task ToggleRegistrationAsync()
    {
        var nextRegistrationState = !_registrationEnabled;

        // Updating local state first keeps the button responsive while persisting the same value to storage.
        _registrationEnabled = nextRegistrationState;

        await ApplicationSettingsStore.SetRegistrationEnabledAsync(nextRegistrationState);
    }

}
