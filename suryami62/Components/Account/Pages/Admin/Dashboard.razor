@page "/Account/Admin"
@using Microsoft.AspNetCore.Authorization
@using suryami62.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject IBlogPostService BlogPostService
@inject IProjectService ProjectService
@inject ApplicationSettingsStore ApplicationSettingsStore

<PageTitle>Admin Dashboard - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <PageHeader Title="Admin" Highlight="Dashboard">
        <ChildContent>
            Manage your blog posts, projects, and other content.
        </ChildContent>
    </PageHeader>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <InfoCard Title="System" IconClass="fas fa-server">
            <div class="flex flex-col gap-4">
                <div class="flex items-center justify-between">
                    <span>Registration:</span>
                    <button @onclick="ToggleRegistration"
                            class="inline-block border-2 border-black @(_registrationEnabled ? "bg-green-400" : "bg-red-400") px-3 py-1 text-sm font-bold shadow-[2px_2px_0px_0px_#000] transition-all active:translate-x-[1px] active:translate-y-[1px] active:shadow-none dark:border-white dark:shadow-[2px_2px_0px_0px_#fff]">
                        @(_registrationEnabled ? "ENABLED" : "DISABLED")
                    </button>
                </div>
                <p class="text-xs text-neutral-500">Enable or disable new user registration.</p>
            </div>
        </InfoCard>

        <InfoCard Title="Posts" IconClass="fas fa-newspaper">
            <div class="flex flex-col gap-4">
                <p>Total posts: @(_postCount)</p>
                <a href="/Account/Admin/Posts"
                   class="inline-block border-2 border-black bg-[#A3E635] px-4 py-2 font-bold shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] dark:border-white dark:bg-lime-500 dark:shadow-[4px_4px_0px_0px_#fff]">
                    MANAGE POSTS
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Projects" IconClass="fas fa-project-diagram">
            <div class="flex flex-col gap-4">
                <p>Total projects: @(_projectCount)</p>
                <a href="/Account/Admin/Projects"
                   class="inline-block border-2 border-black bg-[#FB923C] px-4 py-2 font-bold shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] dark:border-white dark:bg-orange-400 dark:shadow-[4px_4px_0px_0px_#fff]">
                    MANAGE PROJECTS
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Media" IconClass="fas fa-images">
            <div class="flex flex-col gap-4">
                <p>Manage images and assets.</p>
                <a href="/Account/Admin/Media"
                   class="inline-block border-2 border-black bg-[#A855F7] px-4 py-2 font-bold shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] dark:border-white dark:bg-purple-500 dark:shadow-[4px_4px_0px_0px_#fff]">
                    MEDIA GALLERY
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Settings" IconClass="fas fa-cog">
            <div class="flex flex-col gap-4">
                <p>Manage your site settings and profile.</p>
                <a href="/Account/Manage"
                   class="inline-block border-2 border-black bg-[#60A5FA] px-4 py-2 font-bold shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] dark:border-white dark:bg-blue-400 dark:shadow-[4px_4px_0px_0px_#fff]">
                    SITE SETTINGS
                </a>
            </div>
        </InfoCard>

        <InfoCard Title="Logout" IconClass="fas fa-sign-out-alt">
            <div class="flex flex-col gap-4">
                <p>Sign out of your account.</p>
                <form action="/Account/Logout" method="post">
                    <AntiforgeryToken/>
                    <input type="hidden" name="ReturnUrl" value=""/>
                    <button type="submit"
                            class="w-full inline-block border-2 border-black bg-[#EF4444] px-4 py-2 font-bold shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] dark:border-white dark:bg-red-500 dark:shadow-[4px_4px_0px_0px_#fff]">
                        LOGOUT
                    </button>
                </form>
            </div>
        </InfoCard>
    </div>
</div>

@code {
    private int _postCount;
    private int _projectCount;
    private bool _registrationEnabled;

    protected override async Task OnInitializedAsync()
    {
        var (postItems, postTotal) = await BlogPostService.GetPostsAsync(false, take: 0);
        _postCount = postTotal;

        var (projectItems, projectTotal) = await ProjectService.GetProjectsAsync(take: 0);
        _projectCount = projectTotal;

        var settings = await ApplicationSettingsStore.GetAsync();
        _registrationEnabled = settings.RegistrationEnabled;
    }

    private async Task ToggleRegistration()
    {
        _registrationEnabled = !_registrationEnabled;
        await ApplicationSettingsStore.SetRegistrationEnabledAsync(_registrationEnabled);
    }

}
