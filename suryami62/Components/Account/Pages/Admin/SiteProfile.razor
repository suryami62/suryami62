@* Admin page for editing public profile links and contact details. *@
@page "/Account/Admin/SiteProfile"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject SiteProfileSettingsStore SiteProfileSettingsStore

<PageTitle>Site Profile - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <PageHeader Title="Site" Highlight="Profile">
        <ChildContent>
            Update the global social links and public contact details shown on the portfolio.
        </ChildContent>
    </PageHeader>

    @if (HasStatusMessage)
    {
        <div class="@StatusMessageClass">
            <p class="font-bold">@_statusMessage</p>
        </div>
    }

    <section class="neo-card p-6">
        <EditForm Model="FormInput" FormName="siteProfile" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator/>
            <ValidationSummary class="@ValidationSummaryClass" role="alert"/>

            <div class="mt-4 flex max-w-xl flex-col gap-4">
                <div class="flex flex-col gap-2">
                    <label for="FormInput.Instagram"
                           class="text-sm font-black uppercase tracking-widest">Instagram</label>
                    <InputText @bind-Value="FormInput.Instagram" id="FormInput.Instagram"
                               class="@InputClass"
                               placeholder="https://instagram.com/username"/>
                    <ValidationMessage For="() => FormInput.Instagram"
                                       class="@ValidationMessageClass"/>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="FormInput.Linkedin"
                           class="text-sm font-black uppercase tracking-widest">LinkedIn</label>
                    <InputText @bind-Value="FormInput.Linkedin" id="FormInput.Linkedin"
                               class="@InputClass"
                               placeholder="https://linkedin.com/in/username"/>
                    <ValidationMessage For="() => FormInput.Linkedin"
                                       class="@ValidationMessageClass"/>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="FormInput.Github" class="text-sm font-black uppercase tracking-widest">GitHub</label>
                    <InputText @bind-Value="FormInput.Github" id="FormInput.Github"
                               class="@InputClass"
                               placeholder="https://github.com/username"/>
                    <ValidationMessage For="() => FormInput.Github"
                                       class="@ValidationMessageClass"/>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="FormInput.Email" class="text-sm font-black uppercase tracking-widest">Public
                        Email</label>
                    <InputText @bind-Value="FormInput.Email" id="FormInput.Email"
                               class="@InputClass"
                               placeholder="mailto:user@domain.com"/>
                    <ValidationMessage For="() => FormInput.Email"
                                       class="@ValidationMessageClass"/>
                </div>
                <button type="submit" disabled="@_isSubmitting"
                        class="neo-button w-full text-center disabled:cursor-not-allowed disabled:opacity-50">
                    @(_isSubmitting ? "Saving..." : "Save")
                </button>
            </div>
        </EditForm>
    </section>
</div>

@code {
    private const string InputClass = "neo-input";
    private const string ValidationSummaryClass = "text-sm font-bold text-red-600 dark:text-red-400";
    private const string ValidationMessageClass = "text-sm font-bold text-red-600 dark:text-red-400";

    private string StatusMessageClass =>
        $"neo-card p-4 {(_isError ? "bg-red-100 text-red-600 dark:bg-red-900/40 dark:text-red-300" : "bg-green-100 text-green-600 dark:bg-green-900/40 dark:text-green-300")}";

    private bool _isSubmitting;
    private string? _statusMessage;
    private bool _isError;

    private bool HasStatusMessage => !string.IsNullOrWhiteSpace(_statusMessage);

    [SupplyParameterFromForm] private InputModel FormInput { get; set; } = default!;

    /// <summary>
    ///     Loads the persisted public profile settings into the admin form.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        FormInput ??= new InputModel();
        await LoadFormInputAsync();
    }

    /// <summary>
    ///     Persists the form values as public site profile settings.
    /// </summary>
    private async Task OnValidSubmitAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        BeginSubmission();

        try
        {
            await SaveSiteProfileAsync();
            SetSuccessStatus("Site profile updated successfully.");
        }
        catch
        {
            SetErrorStatus("Failed to update site profile.");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    /// <summary>
    ///     Loads the existing profile values so the form always starts from the current persisted state.
    /// </summary>
    private async Task LoadFormInputAsync()
    {
        var siteProfile = await SiteProfileSettingsStore.GetAsync();
        ApplySiteProfileToForm(siteProfile);
    }

    private void ApplySiteProfileToForm(SiteProfileSettings siteProfile)
    {
        FormInput.Instagram ??= siteProfile.Instagram;
        FormInput.Linkedin ??= siteProfile.Linkedin;
        FormInput.Github ??= siteProfile.Github;
        FormInput.Email ??= siteProfile.Email;
    }

    private void BeginSubmission()
    {
        _isSubmitting = true;
        ClearStatus();
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _isError = false;
    }

    private async Task SaveSiteProfileAsync()
    {
        await SiteProfileSettingsStore.SaveAsync(CreateSettingsFromForm());
    }

    private SiteProfileSettings CreateSettingsFromForm()
    {
        return new SiteProfileSettings(
            FormInput.Instagram ?? string.Empty,
            FormInput.Linkedin ?? string.Empty,
            FormInput.Github ?? string.Empty,
            FormInput.Email ?? string.Empty);
    }

    private void SetSuccessStatus(string message)
    {
        _statusMessage = message;
        _isError = false;
    }

    private void SetErrorStatus(string message)
    {
        _statusMessage = message;
        _isError = true;
    }

    /// <summary>
    ///     Captures editable site profile values before they are persisted into the settings store.
    /// </summary>
    private sealed class InputModel
    {
        [WebUrl] [Display(Name = "Instagram")] public string? Instagram { get; set; }

        [WebUrl] [Display(Name = "LinkedIn")] public string? Linkedin { get; set; }

        [WebUrl] [Display(Name = "GitHub")] public string? Github { get; set; }

        [WebOrMailtoUrl]
        [Display(Name = "Public email")]
        public string? Email { get; set; }
    }

    /// <summary>
    ///     Validates absolute URLs and restricts the allowed schemes for profile fields.
    /// </summary>
    private abstract class AbsoluteUrlValidationAttribute : ValidationAttribute
    {
        private readonly string[] _allowedSchemes;

        protected AbsoluteUrlValidationAttribute(params string[] allowedSchemes)
        {
            _allowedSchemes = allowedSchemes;
        }

        protected override ValidationResult? IsValid(object? value, ValidationContext validationContext)
        {
            if (value is null)
            {
                return ValidationResult.Success;
            }

            if (value is not string text)
            {
                return new ValidationResult("Invalid value.");
            }

            if (string.IsNullOrWhiteSpace(text))
            {
                return ValidationResult.Success;
            }

            if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            {
                return new ValidationResult("Must be a valid absolute URL.");
            }

            if (IsAllowedScheme(uri))
            {
                return ValidationResult.Success;
            }

            return new ValidationResult(BuildSchemeValidationMessage());
        }

        private bool IsAllowedScheme(Uri uri)
        {
            return _allowedSchemes.Contains(uri.Scheme, StringComparer.OrdinalIgnoreCase);
        }

        private string BuildSchemeValidationMessage()
        {
            var allowedSchemeLabels = _allowedSchemes
                .Select(scheme => $"{scheme}://")
                .ToArray();

            if (allowedSchemeLabels.Length == 1)
            {
                return $"URL must start with {allowedSchemeLabels[0]}";
            }

            if (allowedSchemeLabels.Length == 2)
            {
                return $"URL must start with {allowedSchemeLabels[0]} or {allowedSchemeLabels[1]}";
            }

            var lastScheme = allowedSchemeLabels[^1];
            var leadingSchemes = string.Join(", ", allowedSchemeLabels[..^1]);

            return $"URL must start with {leadingSchemes}, or {lastScheme}";
        }
    }

    /// <summary>
    ///     Allows public social links that should resolve to standard web URLs.
    /// </summary>
    private sealed class WebUrlAttribute : AbsoluteUrlValidationAttribute
    {
        public WebUrlAttribute() : base("http", "https")
        {
        }
    }

    /// <summary>
    ///     Allows either a web URL or a mailto link for the public contact field.
    /// </summary>
    private sealed class WebOrMailtoUrlAttribute : AbsoluteUrlValidationAttribute
    {
        public WebOrMailtoUrlAttribute() : base("http", "https", "mailto")
        {
        }

        protected override ValidationResult? IsValid(object? value, ValidationContext validationContext)
        {
            var baseResult = base.IsValid(value, validationContext);
            if (baseResult == ValidationResult.Success)
            {
                return ValidationResult.Success;
            }

            if (value is string text && text.StartsWith("mailto:", StringComparison.OrdinalIgnoreCase))
            {
                return ValidationResult.Success;
            }

            return new ValidationResult("URL must start with http://, https://, or mailto:");
        }
    }

}