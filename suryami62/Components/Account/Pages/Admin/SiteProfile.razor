@* Admin page for editing public profile links and contact details. *@
@page "/Account/Admin/SiteProfile"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject SiteProfileSettingsStore SiteProfileSettingsStore

<PageTitle>Site Profile - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <PageHeader Title="Site" Highlight="Profile">
        <ChildContent>
            Update the global social links and public contact details shown on the portfolio.
        </ChildContent>
    </PageHeader>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="@StatusMessageClass">
            <p class="font-bold">@_statusMessage</p>
        </div>
    }

    <section class="neo-card p-6">
        <EditForm Model="Input" FormName="siteProfile" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator/>
            <ValidationSummary class="@ValidationSummaryClass" role="alert"/>

            <div class="mt-4 flex max-w-xl flex-col gap-4">
                <div class="flex flex-col gap-2">
                    <label for="Input.Instagram" class="text-sm font-black uppercase tracking-widest">Instagram</label>
                    <InputText @bind-Value="Input.Instagram" id="Input.Instagram"
                               class="@InputClass"
                               placeholder="https://instagram.com/username"/>
                    <ValidationMessage For="() => Input.Instagram"
                                       class="@ValidationMessageClass"/>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="Input.Linkedin" class="text-sm font-black uppercase tracking-widest">LinkedIn</label>
                    <InputText @bind-Value="Input.Linkedin" id="Input.Linkedin"
                               class="@InputClass"
                               placeholder="https://linkedin.com/in/username"/>
                    <ValidationMessage For="() => Input.Linkedin"
                                       class="@ValidationMessageClass"/>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="Input.Github" class="text-sm font-black uppercase tracking-widest">GitHub</label>
                    <InputText @bind-Value="Input.Github" id="Input.Github"
                               class="@InputClass"
                               placeholder="https://github.com/username"/>
                    <ValidationMessage For="() => Input.Github"
                                       class="@ValidationMessageClass"/>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="Input.Email" class="text-sm font-black uppercase tracking-widest">Public Email</label>
                    <InputText @bind-Value="Input.Email" id="Input.Email"
                               class="@InputClass"
                               placeholder="mailto:user@domain.com"/>
                    <ValidationMessage For="() => Input.Email"
                                       class="@ValidationMessageClass"/>
                </div>
                <button type="submit" disabled="@_isSubmitting"
                        class="neo-button w-full text-center disabled:cursor-not-allowed disabled:opacity-50">
                    @(_isSubmitting ? "Saving..." : "Save")
                </button>
            </div>
        </EditForm>
    </section>
</div>

@code {
    private const string InputClass = "neo-input";
    private const string ValidationSummaryClass = "text-sm font-bold text-red-600 dark:text-red-400";
    private const string ValidationMessageClass = "text-sm font-bold text-red-600 dark:text-red-400";

    private string StatusMessageClass =>
        $"neo-card p-4 {(_isError ? "bg-red-100 text-red-600 dark:bg-red-900/40 dark:text-red-300" : "bg-green-100 text-green-600 dark:bg-green-900/40 dark:text-green-300")}";

    private bool _isSubmitting;
    private string? _statusMessage;
    private bool _isError;

    [SupplyParameterFromForm] private InputModel Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new InputModel();

        var siteProfile = await SiteProfileSettingsStore.GetAsync();
        Input.Instagram ??= siteProfile.Instagram;
        Input.Linkedin ??= siteProfile.Linkedin;
        Input.Github ??= siteProfile.Github;
        Input.Email ??= siteProfile.Email;
    }

    private async Task OnValidSubmitAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;
        _statusMessage = null;
        _isError = false;

        try
        {
            await SiteProfileSettingsStore.SaveAsync(new SiteProfileSettings(
                Input.Instagram ?? string.Empty,
                Input.Linkedin ?? string.Empty,
                Input.Github ?? string.Empty,
                Input.Email ?? string.Empty));

            _statusMessage = "Site profile updated successfully.";
        }
        catch
        {
            _statusMessage = "Failed to update site profile.";
            _isError = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class InputModel
    {
        [WebUrl] [Display(Name = "Instagram")] public string? Instagram { get; set; }

        [WebUrl] [Display(Name = "LinkedIn")] public string? Linkedin { get; set; }

        [WebUrl] [Display(Name = "GitHub")] public string? Github { get; set; }

        [WebOrMailtoUrl]
        [Display(Name = "Public email")]
        public string? Email { get; set; }
    }

    private sealed class WebUrlAttribute : ValidationAttribute
    {
        protected override ValidationResult? IsValid(object? value, ValidationContext validationContext)
        {
            if (value is null)
            {
                return ValidationResult.Success;
            }

            if (value is not string text)
            {
                return new ValidationResult("Invalid value.");
            }

            if (string.IsNullOrWhiteSpace(text))
            {
                return ValidationResult.Success;
            }

            if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            {
                return new ValidationResult("Must be a valid absolute URL.");
            }

            return uri.Scheme is "http" or "https"
                ? ValidationResult.Success
                : new ValidationResult("URL must start with http:// or https://");
        }
    }

    private sealed class WebOrMailtoUrlAttribute : ValidationAttribute
    {
        protected override ValidationResult? IsValid(object? value, ValidationContext validationContext)
        {
            if (value is null)
            {
                return ValidationResult.Success;
            }

            if (value is not string text)
            {
                return new ValidationResult("Invalid value.");
            }

            if (string.IsNullOrWhiteSpace(text))
            {
                return ValidationResult.Success;
            }

            if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            {
                return new ValidationResult("Must be a valid absolute URL.");
            }

            return uri.Scheme is "http" or "https" or "mailto"
                ? ValidationResult.Success
                : new ValidationResult("URL must start with http://, https://, or mailto:");
        }
    }

}