@* Admin page for managing experience and education timeline entries. *@
@page "/Account/Admin/Journey"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using suryami62.Domain.Models
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject IJourneyHistoryService JourneyHistoryService

<PageTitle>Manage Journey - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <PageHeader Title="Manage" Highlight="Journey">
        <ChildContent>
            Add and remove experience and education history shown on the About page.
        </ChildContent>
    </PageHeader>

    @if (HasStatusMessage)
    {
        <div class="@StatusMessageClass">
            @_statusMessage
        </div>
    }

    <div class="grid gap-8 lg:grid-cols-2">
        <section class="neo-card p-6">
            <h2 class="text-2xl font-black uppercase">Experience</h2>

            <EditForm Model="_experienceInput" OnValidSubmit="AddExperienceAsync" class="mt-6 flex flex-col gap-4">
                <DataAnnotationsValidator/>

                <InputText @bind-Value="_experienceInput.Title"
                           class="@InputClass"
                           placeholder="Title"/>
                <ValidationMessage For="() => _experienceInput.Title"
                                   class="text-sm font-bold text-red-600 dark:text-red-400"/>

                <InputText @bind-Value="_experienceInput.Organization"
                           class="@InputClass"
                           placeholder="Organization"/>
                <ValidationMessage For="() => _experienceInput.Organization"
                                   class="text-sm font-bold text-red-600 dark:text-red-400"/>

                <InputText @bind-Value="_experienceInput.Period"
                           class="@InputClass"
                           placeholder="Period"/>
                <ValidationMessage For="() => _experienceInput.Period"
                                   class="text-sm font-bold text-red-600 dark:text-red-400"/>

                <InputTextArea @bind-Value="_experienceInput.Summary"
                               class="@TextAreaInputClass"
                               placeholder="Short summary"/>

                <button type="submit"
                        class="@AddExperienceButtonClass">
                    ADD EXPERIENCE
                </button>
            </EditForm>

            <div class="mt-8 flex flex-col gap-4">
                @if (!HasExperienceEntries)
                {
                    <p class="font-bold text-neutral-500">No experience entries.</p>
                }
                else
                {
                    @foreach (var item in _journey.Experiences)
                    {
                        <article class="border-2 border-black p-4 dark:border-white">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <h3 class="text-xl font-black">@item.Title</h3>
                                    <p class="font-bold text-neutral-600 dark:text-neutral-400">@item.Organization</p>
                                    <p class="text-sm font-mono">@item.Period</p>
                                </div>
                                <button @onclick="() => DeleteExperienceAsync(item.Id)"
                                        class="@DeleteButtonClass">
                                    DELETE
                                </button>
                            </div>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="neo-card p-6">
            <h2 class="text-2xl font-black uppercase">Education</h2>

            <EditForm Model="_educationInput" OnValidSubmit="AddEducationAsync" class="mt-6 flex flex-col gap-4">
                <DataAnnotationsValidator/>

                <InputText @bind-Value="_educationInput.Title"
                           class="@InputClass"
                           placeholder="Degree / Title"/>
                <ValidationMessage For="() => _educationInput.Title"
                                   class="text-sm font-bold text-red-600 dark:text-red-400"/>

                <InputText @bind-Value="_educationInput.Organization"
                           class="@InputClass"
                           placeholder="School / University"/>
                <ValidationMessage For="() => _educationInput.Organization"
                                   class="text-sm font-bold text-red-600 dark:text-red-400"/>

                <InputText @bind-Value="_educationInput.Period"
                           class="@InputClass"
                           placeholder="Period"/>
                <ValidationMessage For="() => _educationInput.Period"
                                   class="text-sm font-bold text-red-600 dark:text-red-400"/>

                <InputTextArea @bind-Value="_educationInput.Summary"
                               class="@TextAreaInputClass"
                               placeholder="Short summary"/>

                <button type="submit"
                        class="@AddEducationButtonClass">
                    ADD EDUCATION
                </button>
            </EditForm>

            <div class="mt-8 flex flex-col gap-4">
                @if (!HasEducationEntries)
                {
                    <p class="font-bold text-neutral-500">No education entries.</p>
                }
                else
                {
                    @foreach (var item in _journey.Educations)
                    {
                        <article class="border-2 border-black p-4 dark:border-white">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <h3 class="text-xl font-black">@item.Title</h3>
                                    <p class="font-bold text-neutral-600 dark:text-neutral-400">@item.Organization</p>
                                    <p class="text-sm font-mono">@item.Period</p>
                                </div>
                                <button @onclick="() => DeleteEducationAsync(item.Id)"
                                        class="@DeleteButtonClass">
                                    DELETE
                                </button>
                            </div>
                        </article>
                    }
                }
            </div>
        </section>
    </div>
</div>

@code {
    private const string InputClass = "neo-input";
    private const string TextAreaInputClass = "neo-input h-28";
    private const string AddExperienceButtonClass = "neo-button bg-lime-400 px-4 py-3 text-black hover:bg-lime-500 dark:bg-lime-500";
    private const string AddEducationButtonClass = "neo-button bg-orange-400 px-4 py-3 text-black hover:bg-orange-500 dark:bg-orange-500";
    private const string DeleteButtonClass = "neo-button-danger px-3 py-1 text-xs";

    private string StatusMessageClass =>
        $"neo-card p-4 font-bold {(_isError ? "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300" : "bg-lime-100 text-lime-700 dark:bg-lime-900/40 dark:text-lime-300")}";

    private JourneyViewModel _journey = new([], []);
    private JourneyInputModel _experienceInput = new();
    private JourneyInputModel _educationInput = new();
    private string? _statusMessage;
    private bool _isError;

    private bool HasStatusMessage => !string.IsNullOrWhiteSpace(_statusMessage);

    private bool HasExperienceEntries => _journey.Experiences.Count > 0;

    private bool HasEducationEntries => _journey.Educations.Count > 0;

    /// <summary>
    ///     Loads both journey sections required by the admin page.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadJourneyAsync();
    }

    /// <summary>
    ///     Reloads experience and education entries from the application layer.
    /// </summary>
    private async Task LoadJourneyAsync()
    {
        var experiences = await LoadJourneySectionAsync(JourneySection.Experience);
        var educations = await LoadJourneySectionAsync(JourneySection.Education);

        _journey = new JourneyViewModel(experiences, educations);
    }

    /// <summary>
    ///     Adds a new experience entry and refreshes the timeline.
    /// </summary>
    private async Task AddExperienceAsync()
    {
        await AddJourneyEntryAsync(
            JourneySection.Experience,
            _experienceInput,
            ResetExperienceInput,
            "Experience added successfully.",
            "Failed to add experience.");
    }

    /// <summary>
    ///     Adds a new education entry and refreshes the timeline.
    /// </summary>
    private async Task AddEducationAsync()
    {
        await AddJourneyEntryAsync(
            JourneySection.Education,
            _educationInput,
            ResetEducationInput,
            "Education added successfully.",
            "Failed to add education.");
    }

    /// <summary>
    ///     Deletes an experience entry and refreshes the timeline.
    /// </summary>
    private async Task DeleteExperienceAsync(int id)
    {
        await DeleteJourneyEntryAsync(
            id,
            "Experience deleted successfully.",
            "Failed to delete experience.");
    }

    /// <summary>
    ///     Deletes an education entry and refreshes the timeline.
    /// </summary>
    private async Task DeleteEducationAsync(int id)
    {
        await DeleteJourneyEntryAsync(
            id,
            "Education deleted successfully.",
            "Failed to delete education.");
    }

    /// <summary>
    ///     Loads a single journey section from the application service.
    /// </summary>
    private Task<List<JourneyHistory>> LoadJourneySectionAsync(JourneySection section)
    {
        return JourneyHistoryService.GetBySectionAsync(section);
    }

    /// <summary>
    ///     Creates a journey entry, resets the form, and reloads the latest persisted data.
    /// </summary>
    private async Task AddJourneyEntryAsync(
        JourneySection section,
        JourneyInputModel input,
        Action resetInput,
        string successMessage,
        string failureMessage)
    {
        try
        {
            var entry = CreateJourneyEntry(section, input);

            await JourneyHistoryService.CreateAsync(entry);
            resetInput();
            await RefreshJourneyAfterMutationAsync(successMessage);
        }
        catch (Exception)
        {
            SetStatus(true, failureMessage);
        }
    }

    /// <summary>
    ///     Deletes a journey entry and reloads the latest persisted data.
    /// </summary>
    private async Task DeleteJourneyEntryAsync(int id, string successMessage, string failureMessage)
    {
        try
        {
            await JourneyHistoryService.DeleteAsync(id);
            await RefreshJourneyAfterMutationAsync(successMessage);
        }
        catch (Exception)
        {
            SetStatus(true, failureMessage);
        }
    }

    private static JourneyHistory CreateJourneyEntry(JourneySection section, JourneyInputModel input)
    {
        return new JourneyHistory
        {
            Section = section,
            Title = input.Title,
            Organization = input.Organization,
            Period = input.Period,
            Summary = input.Summary
        };
    }

    private async Task RefreshJourneyAfterMutationAsync(string successMessage)
    {
        // Reloading after each mutation keeps the admin view aligned with the persisted display order.
        await LoadJourneyAsync();
        SetStatus(false, successMessage);
    }

    private void ResetExperienceInput()
    {
        _experienceInput = new JourneyInputModel();
    }

    private void ResetEducationInput()
    {
        _educationInput = new JourneyInputModel();
    }

    private void SetStatus(bool isError, string message)
    {
        _isError = isError;
        _statusMessage = message;
    }

    /// <summary>
    ///     Captures editable form values before they are mapped into a domain journey entry.
    /// </summary>
    private sealed class JourneyInputModel
    {
        [Required] public string Title { get; set; } = string.Empty;

        [Required] public string Organization { get; set; } = string.Empty;

        [Required] public string Period { get; set; } = string.Empty;

        public string Summary { get; set; } = string.Empty;
    }

    /// <summary>
    ///     Groups journey entries by section so the page can render each column independently.
    /// </summary>
    private sealed record JourneyViewModel(
        IReadOnlyList<JourneyHistory> Experiences,
        IReadOnlyList<JourneyHistory> Educations);

}
