@* Admin listing page for browsing and managing blog posts. *@
@page "/Account/Admin/Posts"
@using Microsoft.AspNetCore.Authorization
@using suryami62.Domain.Models
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject IBlogPostService BlogPostService

<PageTitle>Manage Posts - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <div class="flex items-center justify-between">
        <PageHeader Title="Manage" Highlight="Posts"/>
        <a href="/Account/Admin/Posts/New"
           class="@AddButtonClass">
            ADD NEW POST
        </a>
    </div>

    <div class="neo-card overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-black text-white dark:bg-white dark:text-black">
            <tr>
                <th class="p-4 font-black uppercase">Title</th>
                <th class="p-4 font-black uppercase">Date</th>
                <th class="p-4 font-black uppercase">Status</th>
                <th class="p-4 font-black uppercase">Actions</th>
            </tr>
            </thead>
            <tbody class="divide-y-2 divide-black dark:divide-white">
            @if (IsLoadingPosts)
            {
                <tr>
                    <td colspan="4" class="p-4">Loading...</td>
                </tr>
            }
            else if (HasNoPosts)
            {
                <tr>
                    <td colspan="4" class="p-4">No posts found.</td>
                </tr>
            }
            else if (_posts is { Count: > 0 } posts)
            {
                foreach (var post in posts)
                {
                    <tr class="hover:bg-gray-100 dark:hover:bg-gray-900">
                        <td class="p-4 font-bold">@post.Title</td>
                        <td class="p-4">@post.Date.ToString("MMM dd, yyyy")</td>
                        <td class="p-4">
                            <span class="@GetPostStatusBadgeClass(post)">@GetPostStatusText(post)</span>
                        </td>
                        <td class="flex gap-2 p-4">
                            <a href="/Account/Admin/Posts/Edit/@post.Id"
                               class="@EditButtonClass">EDIT</a>
                            <button @onclick="() => DeletePostAsync(post.Id)"
                                    disabled="@IsDeletingPost(post.Id)"
                                    class="@DeleteButtonClass">
                                @(IsDeletingPost(post.Id) ? "..." : "DELETE")
                            </button>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    @if (ShouldShowPagination)
    {
        <div class="flex justify-center gap-4">
            <button disabled="@(!CanMoveToPreviousPage)" @onclick="GoToPreviousPageAsync"
                    class="@PagerPrevButtonClass">
                PREV
            </button>
            <div class="flex items-center text-2xl font-black">
                @_page / @TotalPages
            </div>
            <button disabled="@(!CanMoveToNextPage)" @onclick="GoToNextPageAsync"
                    class="@PagerNextButtonClass">
                NEXT
            </button>
        </div>
    }
</div>

<ConfirmModal @ref="_confirmModal" Title="Delete Post"
              Message="Are you sure you want to delete this post? This action cannot be undone."/>

@code {
    private const string AddButtonClass = "neo-button-lime px-6 py-3 text-xl";
    private const string EditButtonClass = "neo-button-blue px-3 py-1 text-sm";
    private const string DeleteButtonClass = "neo-button-danger px-3 py-1 text-sm disabled:opacity-50";
    private const string PagerPrevButtonClass = "neo-button px-6 py-2 disabled:opacity-50";
    private const string PagerNextButtonClass = "neo-button-lime px-6 py-2";
    private const string PublishedStatusBadgeClass = "neo-status-published";
    private const string DraftStatusBadgeClass = "neo-status-draft";

    private List<BlogPost>? _posts;
    private int _page = 1;
    private readonly int _pageSize = 10;
    private int _total;
    private int? _isDeleting;
    private ConfirmModal? _confirmModal;

    private bool IsLoadingPosts => _posts is null;

    private bool HasNoPosts => _posts is { Count: 0 };

    private bool ShouldShowPagination => _total > _pageSize;

    private bool CanMoveToPreviousPage => _page > 1;

    private bool CanMoveToNextPage => _page * _pageSize < _total;

    private int TotalPages => (int)Math.Ceiling((double)_total / _pageSize);

    /// <summary>
    ///     Loads the first page of posts for the admin listing.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadPostsAsync();
    }

    /// <summary>
    ///     Reads the posts for the current page and refreshes the pager metadata.
    /// </summary>
    private async Task LoadPostsAsync()
    {
        var pageOffset = GetCurrentPageOffset();
        var (posts, totalPosts) = await BlogPostService.GetPostsAsync(
            false,
            pageOffset,
            _pageSize);

        _posts = posts;
        _total = totalPosts;
    }

    /// <summary>
    ///     Moves the pager to a specific page and reloads the grid.
    /// </summary>
    private async Task ChangePageAsync(int newPage)
    {
        if (newPage < 1)
        {
            return;
        }

        _page = newPage;
        await LoadPostsAsync();
    }

    /// <summary>
    ///     Moves to the previous page when the pager allows it.
    /// </summary>
    private Task GoToPreviousPageAsync()
    {
        return ChangePageAsync(_page - 1);
    }

    /// <summary>
    ///     Moves to the next page when more posts are available.
    /// </summary>
    private Task GoToNextPageAsync()
    {
        return ChangePageAsync(_page + 1);
    }

    /// <summary>
    ///     Deletes a post after user confirmation.
    /// </summary>
    private async Task DeletePostAsync(int postId)
    {
        if (!await ShouldDeletePostAsync())
        {
            return;
        }

        _isDeleting = postId;

        try
        {
            await BlogPostService.DeletePostAsync(postId);
            RemovePostFromCurrentList(postId);
        }
        finally
        {
            // Resetting the busy flag in finally prevents the row button from getting stuck after a failed delete.
            _isDeleting = null;
        }
    }

    private int GetCurrentPageOffset()
    {
        return (_page - 1) * _pageSize;
    }

    private bool IsDeletingPost(int postId)
    {
        return _isDeleting == postId;
    }

    private string GetPostStatusText(BlogPost post)
    {
        return post.IsPublished ? "PUBLISHED" : "DRAFT";
    }

    private string GetPostStatusBadgeClass(BlogPost post)
    {
        return post.IsPublished ? PublishedStatusBadgeClass : DraftStatusBadgeClass;
    }

    private async Task<bool> ShouldDeletePostAsync()
    {
        if (_confirmModal is null)
        {
            return false;
        }

        return await _confirmModal.ShowAsync();
    }

    private void RemovePostFromCurrentList(int postId)
    {
        _posts?.RemoveAll(post => post.Id == postId);
    }

}