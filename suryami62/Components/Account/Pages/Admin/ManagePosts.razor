@page "/Account/Admin/Posts"
@using Microsoft.AspNetCore.Authorization
@using suryami62.Domain.Models
@using suryami62.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject IBlogPostService BlogPostService

<PageTitle>Manage Posts - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <div class="flex items-center justify-between">
        <PageHeader Title="Manage" Highlight="Posts"/>
        <a href="/Account/Admin/Posts/New"
           class="@AddButtonClass">
            ADD NEW POST
        </a>
    </div>

    <div class="neo-card overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-black text-white dark:bg-white dark:text-black">
            <tr>
                <th class="p-4 font-black uppercase">Title</th>
                <th class="p-4 font-black uppercase">Date</th>
                <th class="p-4 font-black uppercase">Status</th>
                <th class="p-4 font-black uppercase">Actions</th>
            </tr>
            </thead>
            <tbody class="divide-y-2 divide-black dark:divide-white">
            @if (_posts == null)
            {
                <tr>
                    <td colspan="4" class="p-4">Loading...</td>
                </tr>
            }
            else if (!_posts.Any())
            {
                <tr>
                    <td colspan="4" class="p-4">No posts found.</td>
                </tr>
            }
            else
            {
                foreach (var post in _posts)
                {
                    <tr class="hover:bg-gray-100 dark:hover:bg-gray-900">
                        <td class="p-4 font-bold">@post.Title</td>
                        <td class="p-4">@post.Date.ToString("MMM dd, yyyy")</td>
                        <td class="p-4">
                            @if (post.IsPublished)
                            {
                                <span
                                    class="bg-green-400 border-2 border-black px-2 py-1 font-bold text-xs">PUBLISHED</span>
                            }
                            else
                            {
                                <span
                                    class="bg-yellow-400 border-2 border-black px-2 py-1 font-bold text-xs">DRAFT</span>
                            }
                        </td>
                        <td class="p-4 flex gap-2">
                            <a href="/Account/Admin/Posts/Edit/@post.Id"
                               class="@EditButtonClass">EDIT</a>
                            <button @onclick="() => DeletePost(post.Id)"
                                    disabled="@(_isDeleting == post.Id)"
                                    class="@DeleteButtonClass">
                                @(_isDeleting == post.Id ? "..." : "DELETE")
                            </button>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    @if (_total > _pageSize)
    {
        <div class="flex justify-center gap-4">
            <button disabled="@(_page == 1)" @onclick="() => ChangePage(_page - 1)"
                    class="@PagerPrevButtonClass">
                PREV
            </button>
            <div class="flex items-center text-2xl font-black">
                @_page / @(Math.Ceiling((double)_total / _pageSize))
            </div>
            <button disabled="@(_page * _pageSize >= _total)" @onclick="() => ChangePage(_page + 1)"
                    class="@PagerNextButtonClass">
                NEXT
            </button>
        </div>
    }
</div>

<ConfirmModal @ref="_confirmModal" Title="Delete Post"
              Message="Are you sure you want to delete this post? This action cannot be undone."/>

@code {
    private const string AddButtonClass = "neo-button bg-[#A3E635] px-6 py-3 text-xl text-black hover:bg-lime-400 dark:bg-lime-500";
    private const string EditButtonClass = "neo-button bg-blue-400 px-3 py-1 text-sm text-black hover:bg-blue-500";
    private const string DeleteButtonClass = "neo-button-danger px-3 py-1 text-sm disabled:opacity-50";
    private const string PagerPrevButtonClass = "neo-button px-6 py-2 text-black disabled:opacity-50";
    private const string PagerNextButtonClass = "neo-button bg-[#A3E635] px-6 py-2 text-black hover:bg-lime-400 disabled:opacity-50 dark:bg-lime-500";

    private List<BlogPost>? _posts;
    private int _page = 1;
    private readonly int _pageSize = 10;
    private int _total;
    private int? _isDeleting;
    private ConfirmModal? _confirmModal;

    protected override async Task OnInitializedAsync()
    {
        await LoadPosts();
    }

    private async Task LoadPosts()
    {
        var (items, total) = await BlogPostService.GetPostsAsync(false, (_page - 1) * _pageSize, _pageSize);
        _posts = items;
        _total = total;
    }

    private async Task ChangePage(int newPage)
    {
        _page = newPage;
        await LoadPosts();
    }

    private async Task DeletePost(int id)
    {
        if (_confirmModal == null) return;

        if (await _confirmModal.ShowAsync())
        {
            _isDeleting = id;
            await BlogPostService.DeletePostAsync(id);
            _posts?.RemoveAll(p => p.Id == id);
            _isDeleting = null;
        }
    }

}