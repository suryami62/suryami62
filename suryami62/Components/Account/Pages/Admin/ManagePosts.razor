@page "/Account/Admin/Posts"
@using Microsoft.AspNetCore.Authorization
@using suryami62.Data.Models
@using suryami62.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject IBlogPostService BlogPostService
@inject NavigationManager NavigationManager

<PageTitle>Manage Posts - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <div class="flex items-center justify-between">
        <PageHeader Title="Manage" Highlight="Posts"/>
        <a href="/Account/Admin/Posts/New"
           class="border-2 border-black bg-[#A3E635] px-6 py-3 text-xl font-black shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] dark:border-white dark:bg-lime-500 dark:shadow-[4px_4px_0px_0px_#fff]">
            ADD NEW POST
        </a>
    </div>

    <div
        class="overflow-x-auto border-4 border-black bg-white shadow-[8px_8px_0px_0px_#000] dark:border-white dark:bg-black dark:shadow-[8px_8px_0px_0px_#fff]">
        <table class="w-full text-left">
            <thead class="bg-black text-white dark:bg-white dark:text-black">
            <tr>
                <th class="p-4 font-black uppercase">Title</th>
                <th class="p-4 font-black uppercase">Date</th>
                <th class="p-4 font-black uppercase">Status</th>
                <th class="p-4 font-black uppercase">Actions</th>
            </tr>
            </thead>
            <tbody class="divide-y-2 divide-black dark:divide-white">
            @if (_posts == null)
            {
                <tr>
                    <td colspan="4" class="p-4">Loading...</td>
                </tr>
            }
            else if (!_posts.Any())
            {
                <tr>
                    <td colspan="4" class="p-4">No posts found.</td>
                </tr>
            }
            else
            {
                foreach (var post in _posts)
                {
                    <tr class="hover:bg-gray-100 dark:hover:bg-gray-900">
                        <td class="p-4 font-bold">@post.Title</td>
                        <td class="p-4">@post.Date.ToString("MMM dd, yyyy")</td>
                        <td class="p-4">
                            @if (post.IsPublished)
                            {
                                <span
                                    class="bg-green-400 border-2 border-black px-2 py-1 font-bold text-xs">PUBLISHED</span>
                            }
                            else
                            {
                                <span
                                    class="bg-yellow-400 border-2 border-black px-2 py-1 font-bold text-xs">DRAFT</span>
                            }
                        </td>
                        <td class="p-4 flex gap-2">
                            <a href="/Account/Admin/Posts/Edit/@post.Id"
                               class="border-2 border-black bg-blue-400 px-3 py-1 font-bold shadow-[2px_2px_0px_0px_#000] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#000]">EDIT</a>
                            <button @onclick="() => DeletePost(post.Id)"
                                    class="border-2 border-black bg-red-400 px-3 py-1 font-bold shadow-[2px_2px_0px_0px_#000] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#000]">
                                DELETE
                            </button>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<BlogPost>? _posts;

    protected override async Task OnInitializedAsync()
    {
        _posts = await BlogPostService.GetPostsAsync(false);
    }

    private async Task DeletePost(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this post?"))
        {
            await BlogPostService.DeletePostAsync(id);
            _posts = await BlogPostService.GetPostsAsync(false);
        }
    }

}

@inject IJSRuntime JS
