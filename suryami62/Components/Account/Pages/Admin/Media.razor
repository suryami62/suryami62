@* Admin media manager for uploading images, browsing the gallery, and copying asset URLs. *@
@page "/Account/Admin/Media"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject IMediaService MediaService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>Media Manager - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <PageHeader Title="Media" Highlight="Manager"/>

    <div class="neo-card p-8">
        <h3 class="mb-6 text-2xl font-black uppercase">Upload New Image</h3>
        <div class="flex flex-col gap-4">
            <InputFile OnChange="HandleFileSelectedAsync"
                       class="@FileInputClass"/>

            @if (_isUploading)
            {
                <div class="flex items-center gap-2">
                    <div
                        class="h-4 w-4 animate-spin rounded-full border-2 border-black border-t-transparent dark:border-white dark:border-t-transparent"></div>
                    <p class="font-bold text-blue-600">Uploading...</p>
                </div>
            }

            @if (HasStatusMessage)
            {
                <div class="@StatusMessageClass">
                    <p class="font-bold">@_statusMessage</p>
                </div>
            }
        </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        @if (IsLoadingGallery)
        {
            <div class="col-span-full py-12 text-center">
                <p class="animate-pulse text-xl font-bold">Loading gallery...</p>
            </div>
        }
        else if (HasNoImages)
        {
            <div class="neo-card col-span-full border-dashed py-12 text-center">
                <p class="font-bold text-gray-500">No images uploaded yet.</p>
            </div>
        }
        else if (_imageFiles is { Count: > 0 } imageFiles)
        {
            @foreach (var file in imageFiles)
            {
                <div class="neo-card group relative overflow-hidden border-2">
                    <div
                        class="aspect-square overflow-hidden border-b-2 border-black bg-gray-100 dark:border-white dark:bg-gray-800">
                        <img src="@BuildImageSource(file)" alt="@file" loading="lazy"
                             class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-110"/>
                    </div>
                    <div class="flex flex-col gap-3 p-3">
                        <p class="truncate text-xs font-bold" title="@file">@file</p>
                        <div class="flex gap-2">
                            <button @onclick="() => CopyToClipboardAsync(file)"
                                    class="@CopyUrlButtonClass">
                                COPY URL
                            </button>
                            <button @onclick="() => ConfirmDeleteAsync(file)"
                                    class="@DeleteButtonClass">
                                DELETE
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<ConfirmModal @ref="_confirmModal" Title="Delete Media"
              Message="Are you sure you want to delete this image? This action cannot be undone."/>

<script src="@Assets["js/utils.js"]"></script>

@code {
    private const string FileInputClass = "neo-input p-4 italic";
    private const string CopyUrlButtonClass = "neo-button-blue px-2 py-1 text-[10px]";
    private const string DeleteButtonClass = "neo-button-danger px-2 py-1 text-[10px]";

    private string StatusMessageClass =>
        $"neo-card p-4 {(_isError ? "bg-red-100 text-red-600 dark:bg-red-900/40 dark:text-red-300" : "bg-green-100 text-green-600 dark:bg-green-900/40 dark:text-green-300")}";

    private List<string>? _imageFiles;
    private bool _isUploading;
    private string? _statusMessage;
    private bool _isError;
    private ConfirmModal? _confirmModal;
    private const long MaxFileSize = 5120000; // 5MB

    private bool HasStatusMessage => !string.IsNullOrEmpty(_statusMessage);

    private bool IsLoadingGallery => _imageFiles is null;

    private bool HasNoImages => _imageFiles is { Count: 0 };

    /// <summary>
    ///     Loads the media gallery shown on the admin page.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadImagesAsync();
    }

    /// <summary>
    ///     Reads the uploaded file list from the media service.
    /// </summary>
    private async Task LoadImagesAsync()
    {
        _imageFiles = await MediaService.ListFilesAsync();
    }

    /// <summary>
    ///     Uploads the selected file and refreshes the gallery when the upload succeeds.
    /// </summary>
    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs e)
    {
        BeginUpload();

        try
        {
            var file = e.File;

            if (!TryValidateFileSize(file, out var validationErrorMessage))
            {
                SetErrorStatus(validationErrorMessage);
                return;
            }

            await using var stream = file.OpenReadStream(MaxFileSize);
            await UploadSelectedFileAsync(file, stream);
        }
        catch (Exception)
        {
            SetErrorStatus("Error: An unexpected error occurred during upload.");
        }
        finally
        {
            _isUploading = false;
        }
    }

    /// <summary>
    ///     Deletes the selected image after the user confirms the action.
    /// </summary>
    private async Task ConfirmDeleteAsync(string fileName)
    {
        if (!await ShouldDeleteImageAsync())
        {
            return;
        }

        var deleted = await MediaService.DeleteFileAsync(fileName);

        if (deleted)
        {
            SetSuccessStatus($"Deleted {fileName}");
            await LoadImagesAsync();
            return;
        }

        SetErrorStatus($"Error: Could not delete {fileName}");
    }

    /// <summary>
    ///     Copies the absolute public URL of the selected image to the clipboard.
    /// </summary>
    private async Task CopyToClipboardAsync(string fileName)
    {
        var absoluteUrl = BuildAbsoluteImageUrl(fileName);

        try
        {
            var result = await JSRuntime.InvokeAsync<bool>("utils.copyTextToClipboard", absoluteUrl);
            if (result)
            {
                SetSuccessStatus($"URL copied: {absoluteUrl}");
            }
            else
            {
                SetErrorStatus("Error: Failed to copy URL.");
            }
        }
        catch (Exception)
        {
            SetErrorStatus("Error: JavaScript interop failed.");
        }
    }

    private void BeginUpload()
    {
        _isUploading = true;
        ClearStatus();
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _isError = false;
    }

    private bool TryValidateFileSize(IBrowserFile file, out string errorMessage)
    {
        if (file.Size <= MaxFileSize)
        {
            errorMessage = string.Empty;
            return true;
        }

        errorMessage = "Error: File size exceeds 5MB limit.";
        return false;
    }

    private async Task UploadSelectedFileAsync(IBrowserFile file, Stream stream)
    {
        var uploadResult = await MediaService.UploadFileAsync(file.Name, file.ContentType, stream);

        if (!uploadResult.Success)
        {
            SetErrorStatus($"Error: {uploadResult.Message}");
            return;
        }

        SetSuccessStatus(uploadResult.Message);

        // Refreshing the gallery after a successful upload keeps the server-rendered list aligned with stored files.
        await LoadImagesAsync();
    }

    private async Task<bool> ShouldDeleteImageAsync()
    {
        if (_confirmModal is null)
        {
            return false;
        }

        return await _confirmModal.ShowAsync();
    }

    private string BuildImageSource(string fileName)
    {
        return $"/img/uploads/{ToEncodedUrlSegment(fileName)}";
    }

    private string BuildAbsoluteImageUrl(string fileName)
    {
        return NavigationManager.ToAbsoluteUri(BuildImageSource(fileName)).ToString();
    }

    private void SetSuccessStatus(string message)
    {
        _statusMessage = message;
        _isError = false;
    }

    private void SetErrorStatus(string message)
    {
        _statusMessage = message;
        _isError = true;
    }

    private static string ToEncodedUrlSegment(string fileName)
    {
        return Uri.EscapeDataString(Uri.UnescapeDataString(fileName));
    }

}
