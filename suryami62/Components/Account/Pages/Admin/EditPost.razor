@page "/Account/Admin/Posts/New"
@page "/Account/Admin/Posts/Edit/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using suryami62.Data.Models
@using suryami62.Services
@implements IAsyncDisposable
@inject IBlogPostService BlogPostService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>@(Id == null ? "New Post" : "Edit Post") - Surya Ramadhan</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="@Assets["ckeditor5/ckeditor5/ckeditor5.css"]"/>
    <link rel="stylesheet" href="@Assets["ckeditor5/style.css"]"/>

    <script type="importmap">
        {
            "imports": {
                "ckeditor5": "/ckeditor5/ckeditor5/ckeditor5.js",
                "ckeditor5/": "/ckeditor5/ckeditor5/"
            }
        }
    </script>
</HeadContent>

<div class="flex flex-col gap-12 py-8">
    <PageHeader Title="@(Id == null ? "New" : "Edit")" Highlight="Post"/>

    <EditForm Model="@_post" OnValidSubmit="SavePost" FormName="edit-post-form"
              class="flex flex-col gap-6 border-4 border-black bg-white p-8 shadow-[8px_8px_0px_0px_#000] dark:border-white dark:bg-black dark:shadow-[8px_8px_0px_0px_#fff]">
        <DataAnnotationsValidator/>
        <ValidationSummary class="text-red-600 font-bold mb-4"/>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Title</label>
                <InputText @bind-Value="_post.Title" @oninput="OnTitleChanged"
                           class="border-2 border-black p-3 font-bold shadow-[4px_4px_0px_0px_#000] focus:translate-x-[2px] focus:translate-y-[2px] focus:shadow-[2px_2px_0px_0px_#000] outline-none dark:border-white dark:bg-gray-900"/>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Slug</label>
                <InputText @bind-Value="_post.Slug"
                           class="border-2 border-black p-3 font-bold shadow-[4px_4px_0px_0px_#000] focus:translate-x-[2px] focus:translate-y-[2px] focus:shadow-[2px_2px_0px_0px_#000] outline-none dark:border-white dark:bg-gray-900"/>
            </div>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Label</label>
                <InputText @bind-Value="_post.Label"
                           class="border-2 border-black p-3 font-bold shadow-[4px_4px_0px_0px_#000] dark:border-white dark:bg-gray-900"/>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Date</label>
                <InputDate @bind-Value="_post.Date"
                           class="border-2 border-black p-3 font-bold shadow-[4px_4px_0px_0px_#000] dark:border-white dark:bg-gray-900"/>
            </div>
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-xl font-black uppercase">Summary</label>
            <InputTextArea @bind-Value="_post.Summary" rows="2"
                           class="border-2 border-black p-3 font-bold shadow-[4px_4px_0px_0px_#000] dark:border-white dark:bg-gray-900"/>
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-xl font-black uppercase">Content</label>
            <div @ref="_editorElement" id="post-content-editor"
                 class="min-h-100 border-2 border-black shadow-[4px_4px_0px_0px_#000] dark:border-white dark:bg-gray-900">
            </div>
            <InputTextArea @bind-Value="_post.Content" class="hidden"/>
        </div>

        <div class="flex items-center gap-4">
            <label class="text-xl font-black uppercase">Published</label>
            <InputCheckbox @bind-Value="_post.IsPublished"
                           class="w-6 h-6 border-2 border-black shadow-[2px_2px_0px_0px_#000]"/>
        </div>

        <div class="flex gap-4 mt-4">
            <button type="submit" disabled="@_isSubmitting"
                    class="border-2 border-black bg-[#A3E635] px-8 py-3 text-xl font-black shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] disabled:opacity-50 dark:border-white dark:bg-lime-500 dark:shadow-[4px_4px_0px_0px_#fff]">
                @(_isSubmitting ? "SAVING..." : "SAVE POST")
            </button>
            <a href="/Account/Admin/Posts"
               class="border-2 border-black bg-gray-200 px-8 py-3 text-xl font-black shadow-[4px_4px_0px_0px_#000] transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000] dark:border-white dark:bg-gray-800 dark:shadow-[4px_4px_0px_0px_#fff]">
                CANCEL
            </a>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private BlogPost _post { get; set; } = default!;
    private bool _isSubmitting;
    private ElementReference _editorElement;
    private IJSObjectReference? _module;
    private DotNetObjectReference<EditPost>? _dotNetHelper;

    protected override void OnInitialized()
    {
        _post ??= new BlogPost { Date = DateTime.UtcNow };
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != null)
        {
            var post = await BlogPostService.GetPostByIdAsync(Id.Value);
            if (post != null)
            {
                _post = post;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/ckeditor5/blazor-ckeditor.js");
            _dotNetHelper = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("init", _editorElement, _dotNetHelper, _post.Content);
        }
    }

    [JSInvokable]
    public void OnEditorChanged(string data)
    {
        _post.Content = data;
        StateHasChanged();
    }

    private void OnTitleChanged(ChangeEventArgs e)
    {
        if (Id == null)
        {
            var title = e.Value?.ToString() ?? "";
            _post.Slug = title.ToLower().Replace(" ", "-").Replace("--", "-").Trim('-');
        }
    }

    private async Task SavePost()
    {
        if (_isSubmitting) return;

        if (_module != null)
        {
            var data = await _module.InvokeAsync<string>("getData", "post-content-editor");
            if (data != null)
            {
                _post.Content = data;
            }
        }

        _isSubmitting = true;

        try
        {
            if (Id == null)
            {
                await BlogPostService.CreatePostAsync(_post);
            }
            else
            {
                await BlogPostService.UpdatePostAsync(_post);
            }

            NavigationManager.NavigateTo("/Account/Admin/Posts");
        }
        catch
        {
            _isSubmitting = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module != null)
            {
                await _module.InvokeVoidAsync("destroy", "post-content-editor");
                await _module.DisposeAsync();
            }

            _dotNetHelper?.Dispose();
        }
        catch (JSDisconnectedException)
        {
        }
    }

}
