@* Admin editor page for creating and updating portfolio projects. *@
@page "/Account/Admin/Projects/New"
@page "/Account/Admin/Projects/Edit/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using suryami62.Domain.Models
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject IProjectService ProjectService
@inject NavigationManager NavigationManager

<PageTitle>@PageTitleText - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <PageHeader Title="@PageActionText" Highlight="Project"/>

    <EditForm Model="@_project" OnValidSubmit="SaveProjectAsync" FormName="edit-project-form" method="post"
              class="neo-card flex flex-col gap-6 p-8">
        <DataAnnotationsValidator/>
        <ValidationSummary class="@ValidationSummaryClass"/>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Title</label>
                <InputText @bind-Value="_project.Title"
                           class="@InputClass"/>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Tags (comma separated)</label>
                <InputText @bind-Value="_project.Tags" placeholder="e.g. .NET, Blazor, Tailwind"
                           class="@InputClass"/>
            </div>
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-xl font-black uppercase">Description</label>
            <InputTextArea @bind-Value="_project.Description" rows="3"
                           class="@InputClass"/>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Repo URL</label>
                <InputText @bind-Value="_repoUrlText"
                           class="@InputClass"/>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Demo URL</label>
                <InputText @bind-Value="_demoUrlText"
                           class="@InputClass"/>
            </div>
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-xl font-black uppercase">Image URL</label>
            <InputText @bind-Value="_imageUrlText" placeholder="https://.../project-screenshot.png"
                       class="@InputClass"/>
        </div>

        <div class="flex w-32 flex-col gap-2">
            <label class="text-xl font-black uppercase">Order</label>
            <InputNumber @bind-Value="_project.DisplayOrder"
                         class="@InputClass"/>
        </div>

        <div class="mt-4 flex gap-4">
            <button type="submit" disabled="@_isSubmitting"
                    class="@PrimaryButtonClass">
                @SubmitButtonText
            </button>
            <a href="/Account/Admin/Projects"
               class="@SecondaryButtonClass">
                CANCEL
            </a>
        </div>
    </EditForm>
</div>

@code {
    private const string InputClass = "neo-input";
    private const string ValidationSummaryClass = "mb-4 font-bold text-red-600 dark:text-red-400";
    private const string PrimaryButtonClass = "neo-button-orange px-8 py-3 text-xl";
    private const string SecondaryButtonClass = "neo-button bg-neutral-200 px-8 py-3 text-xl hover:bg-neutral-300 dark:bg-neutral-700 dark:text-white dark:hover:bg-neutral-600";

    /// <summary>
    ///     Gets the identifier of the project being edited, or <see langword="null" /> when creating a new project.
    /// </summary>
    [Parameter]
    public int? Id { get; set; }

    [SupplyParameterFromForm] private Project _project { get; set; } = default!;
    private string? _repoUrlText;
    private string? _demoUrlText;
    private string? _imageUrlText;
    private bool _isSubmitting;

    private bool IsNewProject => Id is null;

    private string PageActionText => IsNewProject ? "New" : "Edit";

    private string PageTitleText => IsNewProject ? "New Project" : "Edit Project";

    private string SubmitButtonText => _isSubmitting ? "SAVING..." : "SAVE PROJECT";

    /// <summary>
    ///     Creates the initial form model used by the project editor.
    /// </summary>
    protected override void OnInitialized()
    {
        _project ??= new Project();
        SyncUrlTextFromProject();
    }

    /// <summary>
    ///     Loads the requested project when the route changes, or resets the editor for a new project.
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (IsNewProject)
        {
            ResetFormForNewProject();
            return;
        }

        await LoadExistingProjectAsync(Id!.Value);
    }

    private void ResetFormForNewProject()
    {
        _project = new Project();
        SyncUrlTextFromProject();
    }

    private async Task LoadExistingProjectAsync(int projectId)
    {
        var existingProject = await ProjectService.GetProjectByIdAsync(projectId);
        if (existingProject is not null)
        {
            _project = existingProject;
        }

        SyncUrlTextFromProject();
    }

    private void SyncUrlTextFromProject()
    {
        _repoUrlText = _project.RepoUrl?.ToString();
        _demoUrlText = _project.DemoUrl?.ToString();
        _imageUrlText = _project.ImageUrl?.ToString();
    }

    /// <summary>
    ///     Parses an optional absolute URL from a free-form input field.
    /// </summary>
    private static Uri? TryParseAbsoluteUri(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return Uri.TryCreate(value, UriKind.Absolute, out var uri) ? uri : null;
    }

    /// <summary>
    ///     Creates or updates the project, then returns to the admin project listing.
    /// </summary>
    private async Task SaveProjectAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        BeginSubmit();

        try
        {
            ApplyUrlInputsToProject();
            await PersistProjectAsync();
            NavigateToProjectList();
        }
        catch
        {
            // Keeping the current form state after a failed save gives the user a chance to correct and retry.
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void BeginSubmit()
    {
        _isSubmitting = true;
    }

    private void ApplyUrlInputsToProject()
    {
        _project.RepoUrl = TryParseAbsoluteUri(_repoUrlText);
        _project.DemoUrl = TryParseAbsoluteUri(_demoUrlText);
        _project.ImageUrl = TryParseAbsoluteUri(_imageUrlText);
    }

    private Task PersistProjectAsync()
    {
        return IsNewProject
            ? ProjectService.CreateProjectAsync(_project)
            : UpdateProjectAsync();
    }

    private async Task UpdateProjectAsync()
    {
        await ProjectService.UpdateProjectAsync(_project);
    }

    private void NavigateToProjectList()
    {
        NavigationManager.NavigateTo("/Account/Admin/Projects");
    }

}
