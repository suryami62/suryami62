@* Admin editor page for creating and updating portfolio projects. *@
@page "/Account/Admin/Projects/New"
@page "/Account/Admin/Projects/Edit/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using suryami62.Domain.Models
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject IProjectService ProjectService
@inject NavigationManager NavigationManager

<PageTitle>@(Id == null ? "New Project" : "Edit Project") - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <PageHeader Title="@(Id == null ? "New" : "Edit")" Highlight="Project"/>

    <EditForm Model="@_project" OnValidSubmit="SaveProject" FormName="edit-project-form" method="post"
              class="neo-card flex flex-col gap-6 p-8">
        <DataAnnotationsValidator/>
        <ValidationSummary class="@ValidationSummaryClass"/>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Title</label>
                <InputText @bind-Value="_project.Title"
                           class="@InputClass"/>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Tags (comma separated)</label>
                <InputText @bind-Value="_project.Tags" placeholder="e.g. .NET, Blazor, Tailwind"
                           class="@InputClass"/>
            </div>
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-xl font-black uppercase">Description</label>
            <InputTextArea @bind-Value="_project.Description" rows="3"
                           class="@InputClass"/>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Repo URL</label>
                <InputText @bind-Value="_repoUrlText"
                           class="@InputClass"/>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xl font-black uppercase">Demo URL</label>
                <InputText @bind-Value="_demoUrlText"
                           class="@InputClass"/>
            </div>
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-xl font-black uppercase">Image URL</label>
            <InputText @bind-Value="_imageUrlText" placeholder="https://.../project-screenshot.png"
                       class="@InputClass"/>
        </div>

        <div class="flex flex-col gap-2 w-32">
            <label class="text-xl font-black uppercase">Order</label>
            <InputNumber @bind-Value="_project.DisplayOrder"
                         class="@InputClass"/>
        </div>

        <div class="flex gap-4 mt-4">
            <button type="submit" disabled="@_isSubmitting"
                    class="@PrimaryButtonClass">
                @(_isSubmitting ? "SAVING..." : "SAVE PROJECT")
            </button>
            <a href="/Account/Admin/Projects"
               class="@SecondaryButtonClass">
                CANCEL
            </a>
        </div>
    </EditForm>
</div>

@code {
    private const string InputClass = "neo-input";
    private const string ValidationSummaryClass = "mb-4 font-bold text-red-600 dark:text-red-400";
    private const string PrimaryButtonClass = "neo-button bg-[#FB923C] px-8 py-3 text-xl text-black hover:bg-orange-300 disabled:opacity-50 dark:bg-orange-400 dark:text-black";
    private const string SecondaryButtonClass = "neo-button bg-gray-200 px-8 py-3 text-xl text-black hover:bg-gray-300 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700";

    [Parameter] public int? Id { get; set; }

    [SupplyParameterFromForm] private Project _project { get; set; } = default!;
    private string? _repoUrlText;
    private string? _demoUrlText;
    private string? _imageUrlText;
    private bool _isSubmitting;

    protected override void OnInitialized()
    {
        _project ??= new Project();
        SyncUrlTextFromModel();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != null)
        {
            var project = await ProjectService.GetProjectByIdAsync(Id.Value);
            if (project != null)
            {
                _project = project;
            }
        }

        SyncUrlTextFromModel();
    }

    private void SyncUrlTextFromModel()
    {
        _repoUrlText = _project.RepoUrl?.ToString();
        _demoUrlText = _project.DemoUrl?.ToString();
        _imageUrlText = _project.ImageUrl?.ToString();
    }

    private static Uri? TryParseAbsoluteUri(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return Uri.TryCreate(value, UriKind.Absolute, out var uri) ? uri : null;
    }

    private async Task SaveProject()
    {
        if (_isSubmitting) return;
        _isSubmitting = true;

        try
        {
            _project.RepoUrl = TryParseAbsoluteUri(_repoUrlText);
            _project.DemoUrl = TryParseAbsoluteUri(_demoUrlText);
            _project.ImageUrl = TryParseAbsoluteUri(_imageUrlText);

            if (Id == null)
            {
                await ProjectService.CreateProjectAsync(_project);
            }
            else
            {
                await ProjectService.UpdateProjectAsync(_project);
            }

            NavigationManager.NavigateTo("/Account/Admin/Projects");
        }
        catch
        {
            _isSubmitting = false;
        }
    }

}
