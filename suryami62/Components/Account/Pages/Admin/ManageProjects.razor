@* Admin listing page for browsing and managing portfolio projects. *@
@page "/Account/Admin/Projects"
@using Microsoft.AspNetCore.Authorization
@using suryami62.Domain.Models
@attribute [Authorize(Policy = AdminAccessPolicy.Name)]
@rendermode InteractiveServer
@inject IProjectService ProjectService

<PageTitle>Manage Projects - Surya Ramadhan</PageTitle>

<div class="flex flex-col gap-12 py-8">
    <div class="flex items-center justify-between">
        <PageHeader Title="Manage" Highlight="Projects"/>
        <a href="/Account/Admin/Projects/New"
           class="@AddButtonClass">
            ADD NEW PROJECT
        </a>
    </div>

    <div class="neo-card overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-black text-white dark:bg-white dark:text-black">
            <tr>
                <th class="p-4 font-black uppercase">Order</th>
                <th class="p-4 font-black uppercase">Title</th>
                <th class="p-4 font-black uppercase">Tags</th>
                <th class="p-4 font-black uppercase">Actions</th>
            </tr>
            </thead>
            <tbody class="divide-y-2 divide-black dark:divide-white">
            @if (IsLoadingProjects)
            {
                <tr>
                    <td colspan="4" class="p-4">Loading...</td>
                </tr>
            }
            else if (HasNoProjects)
            {
                <tr>
                    <td colspan="4" class="p-4">No projects found.</td>
                </tr>
            }
            else if (_projects is { Count: > 0 } projects)
            {
                foreach (var project in projects)
                {
                    <tr class="hover:bg-gray-100 dark:hover:bg-gray-900">
                        <td class="p-4 font-bold">@project.DisplayOrder</td>
                        <td class="p-4 font-bold">@project.Title</td>
                        <td class="p-4">
                            <div class="flex flex-wrap gap-1">
                                @foreach (var tag in GetProjectTags(project))
                                {
                                    <span class="@ProjectTagBadgeClass">@tag</span>
                                }
                            </div>
                        </td>
                        <td class="flex gap-2 p-4">
                            <a href="/Account/Admin/Projects/Edit/@project.Id"
                               class="@EditButtonClass">EDIT</a>
                            <button @onclick="() => DeleteProjectAsync(project.Id)"
                                    disabled="@IsDeletingProject(project.Id)"
                                    class="@DeleteButtonClass">
                                @(IsDeletingProject(project.Id) ? "..." : "DELETE")
                            </button>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    @if (ShouldShowPagination)
    {
        <div class="flex justify-center gap-4">
            <button disabled="@(!CanMoveToPreviousPage)" @onclick="GoToPreviousPageAsync"
                    class="@PagerPrevButtonClass">
                PREV
            </button>
            <div class="flex items-center text-2xl font-black">
                @_page / @TotalPages
            </div>
            <button disabled="@(!CanMoveToNextPage)" @onclick="GoToNextPageAsync"
                    class="@PagerNextButtonClass">
                NEXT
            </button>
        </div>
    }
</div>

<ConfirmModal @ref="_confirmModal" Title="Delete Project"
              Message="Are you sure you want to delete this project? This action cannot be undone."/>

@code {
    private const string AddButtonClass = "neo-button-orange px-6 py-3 text-xl";
    private const string EditButtonClass = "neo-button-blue px-3 py-1 text-sm";
    private const string DeleteButtonClass = "neo-button-danger px-3 py-1 text-sm disabled:opacity-50";
    private const string PagerPrevButtonClass = "neo-button px-6 py-2 disabled:opacity-50";
    private const string PagerNextButtonClass = "neo-button-orange px-6 py-2";
    private const string ProjectTagBadgeClass = "border border-black bg-gray-200 px-1 text-[10px] font-bold";

    private List<Project>? _projects;
    private int _page = 1;
    private readonly int _pageSize = 10;
    private int _total;
    private int? _isDeleting;
    private ConfirmModal? _confirmModal;

    private bool IsLoadingProjects => _projects is null;

    private bool HasNoProjects => _projects is { Count: 0 };

    private bool ShouldShowPagination => _total > _pageSize;

    private bool CanMoveToPreviousPage => _page > 1;

    private bool CanMoveToNextPage => _page * _pageSize < _total;

    private int TotalPages => (int)Math.Ceiling((double)_total / _pageSize);

    /// <summary>
    ///     Loads the first page of projects for the admin listing.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    /// <summary>
    ///     Reads the projects for the current page and refreshes the pager metadata.
    /// </summary>
    private async Task LoadProjectsAsync()
    {
        var pageOffset = GetCurrentPageOffset();
        var (projects, totalProjects) = await ProjectService.GetProjectsAsync(pageOffset, _pageSize);

        _projects = projects;
        _total = totalProjects;
    }

    /// <summary>
    ///     Moves the pager to a specific page and reloads the grid.
    /// </summary>
    private async Task ChangePageAsync(int newPage)
    {
        if (newPage < 1)
        {
            return;
        }

        _page = newPage;
        await LoadProjectsAsync();
    }

    /// <summary>
    ///     Moves to the previous page when the pager allows it.
    /// </summary>
    private Task GoToPreviousPageAsync()
    {
        return ChangePageAsync(_page - 1);
    }

    /// <summary>
    ///     Moves to the next page when more projects are available.
    /// </summary>
    private Task GoToNextPageAsync()
    {
        return ChangePageAsync(_page + 1);
    }

    /// <summary>
    ///     Deletes a project after user confirmation.
    /// </summary>
    private async Task DeleteProjectAsync(int projectId)
    {
        if (!await ShouldDeleteProjectAsync())
        {
            return;
        }

        _isDeleting = projectId;

        try
        {
            await ProjectService.DeleteProjectAsync(projectId);
            RemoveProjectFromCurrentList(projectId);
        }
        finally
        {
            // Resetting the busy flag in finally prevents the row button from staying disabled after a failed delete.
            _isDeleting = null;
        }
    }

    private int GetCurrentPageOffset()
    {
        return (_page - 1) * _pageSize;
    }

    private bool IsDeletingProject(int projectId)
    {
        return _isDeleting == projectId;
    }

    private IEnumerable<string> GetProjectTags(Project project)
    {
        return project.Tags
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(tag => tag.Trim());
    }

    private async Task<bool> ShouldDeleteProjectAsync()
    {
        if (_confirmModal is null)
        {
            return false;
        }

        return await _confirmModal.ShowAsync();
    }

    private void RemoveProjectFromCurrentList(int projectId)
    {
        _projects?.RemoveAll(project => project.Id == projectId);
    }

}
