@page "/Account/InvalidPasswordReset"

<PageTitle>Invalid password reset</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <header class="border-b-4 border-black pb-6 dark:border-white">
        <h1 class="text-4xl font-black tracking-tighter uppercase md:text-5xl">Invalid password reset</h1>
    </header>
    <div
        class="border-4 border-black bg-neutral-100 p-6 font-bold shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:border-white dark:bg-neutral-900 dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)]"
        role="alert">
        The password reset link is invalid.
    </div>
</div>