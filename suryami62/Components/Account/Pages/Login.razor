@* Primary sign-in page for local account authentication. *@
@page "/Account/Login"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using suryami62.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject ApplicationSettingsStore ApplicationSettingsStore

<PageTitle>Log in</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <header class="border-b-4 border-black pb-6 dark:border-white">
        <h1 class="text-4xl font-black tracking-tighter uppercase md:text-5xl">Log in</h1>
        <p class="mt-2 text-lg font-bold">Use a local account to log in.</p>
    </header>

    <div class="grid gap-8">
        <section class="neo-card p-6">
            <StatusMessage Message="@errorMessage"/>
            @if (editContext is not null)
            {
                <EditForm EditContext="editContext" method="post" OnSubmit="LoginUser" FormName="login">
                    <DataAnnotationsValidator/>
                    <ValidationSummary class="@ValidationSummaryClass" role="alert"/>

                    <div class="mt-4 flex flex-col gap-4">
                        <div class="flex flex-col gap-2">
                            <label for="Input.Email" class="text-sm font-black uppercase tracking-widest">Email</label>
                            <InputText @bind-Value="Input.Email" id="Input.Email"
                                       class="@InputClass"
                                       autocomplete="username" aria-required="true"
                                       placeholder="name@example.com"/>
                            <ValidationMessage For="() => Input.Email"
                                               class="@ValidationMessageClass"/>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="Input.Password"
                                   class="text-sm font-black uppercase tracking-widest">Password</label>
                            <InputText type="password" @bind-Value="Input.Password" id="Input.Password"
                                       class="@InputClass"
                                       autocomplete="current-password" aria-required="true" placeholder="password"/>
                            <ValidationMessage For="() => Input.Password"
                                               class="@ValidationMessageClass"/>
                        </div>
                        <label class="flex items-center gap-3 text-sm font-bold uppercase">
                            <InputCheckbox @bind-Value="Input.RememberMe"
                                           class="h-5 w-5 border-2 border-black bg-white accent-black dark:border-white dark:bg-black dark:accent-white"/>
                            Remember me
                        </label>
                        <button type="submit" disabled="@_isSubmitting"
                                class="neo-button w-full text-center disabled:cursor-not-allowed disabled:opacity-50">
                            @(_isSubmitting ? "Logging in..." : "Log in")
                        </button>
                    </div>

                    <div class="mt-6 border-t-4 border-black pt-6 dark:border-white">
                        <div class="flex flex-col gap-2 text-sm font-bold uppercase">
                            <a class="@InlineLinkClass"
                               href="Account/ForgotPassword">Forgot your password?</a>
                            @if (_registrationEnabled)
                            {
                                <a class="@InlineLinkClass"
                                   href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Register
                                    as a new user</a>
                            }
                            <a class="@InlineLinkClass"
                               href="Account/ResendEmailConfirmation">Resend email confirmation</a>
                        </div>
                    </div>
                </EditForm>
            }
        </section>
    </div>
</div>

@code {
    private const string InputClass = "neo-input";
    private const string ValidationSummaryClass = "text-sm font-bold text-red-600 dark:text-red-400";
    private const string ValidationMessageClass = "text-sm font-bold text-red-600 dark:text-red-400";
    private const string InlineLinkClass = "underline decoration-4 underline-offset-4 hover:text-neutral-600 dark:hover:text-neutral-300";

    private string? errorMessage;
    private bool _isSubmitting;
    private EditContext editContext = default!;
    private bool _registrationEnabled;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm] private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new InputModel();

        editContext = new EditContext(Input);

        var settings = await ApplicationSettingsStore.GetAsync();
        _registrationEnabled = settings.RegistrationEnabled;
    }

    public async Task LoginUser()
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;

        try
        {
            SignInResult result;
            // If doing a password sign-in, validate the form.
            if (!editContext.Validate())
            {
                _isSubmitting = false;
                return;
            }

            // To support logging in with email when it's different from the username,
            // we first find the user by their email address.
            var user = await UserManager.FindByEmailAsync(Input.Email);
            if (user != null)
            {
                result = await SignInManager.PasswordSignInAsync(user.UserName!, Input.Password, Input.RememberMe, true);
            }
            else
            {
                result = SignInResult.Failed;
            }

            if (result.Succeeded)
            {
                Logger.LogInformation("User logged in.");
                RedirectManager.RedirectTo(ReturnUrl);
            }
            else if (result.RequiresTwoFactor)
            {
                RedirectManager.RedirectTo(
                    "Account/LoginWith2fa",
                    new Dictionary<string, object?> { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
            }
            else if (result.IsLockedOut)
            {
                Logger.LogWarning("User account locked out.");
                RedirectManager.RedirectTo("Account/Lockout");
            }
            else
            {
                errorMessage = "Error: Invalid login attempt.";
                _isSubmitting = false;
            }
        }
        catch
        {
            _isSubmitting = false;
            throw;
        }
    }

    private sealed class InputModel
    {
        [Required] [EmailAddress] public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")] public bool RememberMe { get; set; }
    }

}