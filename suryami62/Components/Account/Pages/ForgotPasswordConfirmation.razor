@* Confirmation page shown after a password reset request is submitted. *@
@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Forgot password confirmation</PageTitle>

<div class="flex flex-col gap-8 py-8">
    <header class="border-b-4 border-black pb-6 dark:border-white">
        <h1 class="text-4xl font-black tracking-tighter uppercase md:text-5xl">Forgot password confirmation</h1>
    </header>
    <div class="neo-card max-w-xl p-6 font-bold" role="alert">
        Please check your email to reset your password.
    </div>
</div>